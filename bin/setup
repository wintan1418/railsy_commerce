#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def check_command(cmd, install_hint)
  unless system("which #{cmd} > /dev/null 2>&1")
    puts "\n  ERROR: #{cmd} is not installed or not in PATH."
    puts "  #{install_hint}"
    puts ""
    exit 1
  end
end

FileUtils.chdir APP_ROOT do
  puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  puts "  RailsyCommerce Setup"
  puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"

  # ── Check prerequisites ──
  puts "== Checking prerequisites =="

  check_command("ruby", "Install Ruby 3.4+ via rbenv, asdf, or rvm")
  check_command("node", "Install Node.js 20+ from https://nodejs.org or via nvm")
  check_command("yarn", "Install Yarn: npm install -g yarn")
  check_command("psql", "Install PostgreSQL 15+ from https://www.postgresql.org/download/")

  # Check PostgreSQL is running
  unless system("pg_isready -q 2>/dev/null")
    puts "\n  WARNING: PostgreSQL does not appear to be running."
    puts "  Start it with: sudo service postgresql start (Linux)"
    puts "                 brew services start postgresql (macOS)"
    puts ""
    puts "  Continuing anyway — database setup may fail.\n"
  end

  puts "  All prerequisites found.\n"

  # ── Environment file ──
  puts "\n== Checking environment file =="
  env_file = File.join(APP_ROOT, ".env")
  env_example = File.join(APP_ROOT, ".env.example")

  if File.exist?(env_file)
    puts "  .env file found."
  elsif File.exist?(env_example)
    FileUtils.cp(env_example, env_file)
    puts "  .env file created from .env.example"
    puts "  Please edit .env with your actual API keys before going to production."
  else
    puts "  No .env or .env.example found. Continuing without environment variables."
  end

  # ── Install dependencies ──
  puts "\n== Installing Ruby dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Installing JavaScript dependencies =="
  system!("yarn install")

  # ── Database ──
  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  puts "\n== Seeding database =="
  system! "bin/rails db:seed"

  # ── Cleanup ──
  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  # ── Tests ──
  puts "\n== Running tests =="
  system "bin/rails test"

  # ── Summary ──
  puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  puts "  Setup complete!"
  puts ""
  puts "  Start the server:     bin/dev"
  puts ""
  puts "  URLs:"
  puts "    Storefront:         http://localhost:3000"
  puts "    Admin Panel:        http://localhost:3000/admin"
  puts "    Hire Page:          http://localhost:3000/hire"
  puts ""
  puts "  Admin Credentials:"
  puts "    Email:              admin@railsycommerce.com"
  puts "    Password:           password"
  puts ""
  puts "  Customer Credentials:"
  puts "    Email:              customer@example.com"
  puts "    Password:           password"
  puts ""
  puts "  Next Steps:"
  puts "    1. Edit .env with your Stripe, Google OAuth, and email keys"
  puts "    2. Visit /admin to configure your store"
  puts "    3. See README.md for deployment instructions"
  puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush
    exec "bin/dev"
  end
end
