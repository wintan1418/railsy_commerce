<div class="mx-auto max-w-md px-4 sm:px-6 py-12">
  <h1 class="font-display text-3xl font-light" style="color: var(--black);">My <em class="italic">Profile</em></h1>
  <%= form_with model: current_user, url: account_profile_path, method: :patch, class: "mt-8 space-y-5" do |form| %>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :first_name, class: "block text-sm font-medium", style: "color: var(--text-body);" %>
        <%= form.text_field :first_name, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
      </div>
      <div>
        <%= form.label :last_name, class: "block text-sm font-medium", style: "color: var(--text-body);" %>
        <%= form.text_field :last_name, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
      </div>
    </div>
    <div>
      <%= form.label :email_address, class: "block text-sm font-medium", style: "color: var(--text-body);" %>
      <%= form.email_field :email_address, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
    <%= form.submit "Update Profile", class: "w-full rounded-lg py-3 min-h-[48px] text-sm font-semibold uppercase tracking-wider text-white cursor-pointer", style: "background: var(--gold);" %>
  <% end %>
</div>
