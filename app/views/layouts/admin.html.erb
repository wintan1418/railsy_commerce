<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Admin - RailsyCommerce" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full bg-gray-50 antialiased">
    <div class="flex h-full">
      <!-- Mobile sidebar overlay -->
      <div id="admin-sidebar-overlay" class="fixed inset-0 z-40 bg-black/50 hidden lg:hidden" onclick="document.getElementById('admin-sidebar').classList.add('hidden'); document.getElementById('admin-sidebar').classList.remove('flex'); document.getElementById('admin-sidebar-overlay').classList.add('hidden');"></div>

      <!-- Sidebar -->
      <aside id="admin-sidebar" class="hidden w-64 flex-shrink-0 flex-col bg-gray-900 lg:flex fixed inset-y-0 left-0 z-50 lg:relative">
        <!-- Logo -->
        <div class="flex h-16 items-center justify-between gap-2 px-6 border-b border-gray-800">
          <div class="flex items-center gap-2">
            <svg class="h-7 w-7 text-indigo-400" viewBox="0 0 32 32" fill="currentColor">
              <rect x="2" y="2" width="12" height="12" rx="3"/>
              <rect x="18" y="2" width="12" height="12" rx="3" opacity="0.7"/>
              <rect x="2" y="18" width="12" height="12" rx="3" opacity="0.7"/>
              <rect x="18" y="18" width="12" height="12" rx="3" opacity="0.4"/>
            </svg>
            <span class="text-lg font-bold text-white">RailsyCommerce</span>
          </div>
          <button type="button" class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors lg:hidden"
            onclick="document.getElementById('admin-sidebar').classList.add('hidden'); document.getElementById('admin-sidebar').classList.remove('flex'); document.getElementById('admin-sidebar-overlay').classList.add('hidden');">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
          <%= link_to admin_root_path,
            class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-200 #{request.path == admin_root_path ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
            Dashboard
          <% end %>

          <%= link_to admin_deliveries_path,
            class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-200 #{request.path.start_with?('/admin/deliveries') ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
            </svg>
            Deliveries
          <% end %>

          <%= link_to admin_orders_path,
