<%= form_with model: [:account, address], class: "mt-6 space-y-4" do |form| %>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :first_name, class: "block text-sm font-medium" %>
      <%= form.text_field :first_name, required: true, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
    <div>
      <%= form.label :last_name, class: "block text-sm font-medium" %>
      <%= form.text_field :last_name, required: true, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
  </div>
  <div>
    <%= form.label :address_line_1, class: "block text-sm font-medium" %>
    <%= form.text_field :address_line_1, required: true, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :city, class: "block text-sm font-medium" %>
      <%= form.text_field :city, required: true, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
    <div>
      <%= form.label :state, class: "block text-sm font-medium" %>
      <%= form.text_field :state, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :postal_code, class: "block text-sm font-medium" %>
      <%= form.text_field :postal_code, required: true, class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
    <div>
      <%= form.label :country_code, class: "block text-sm font-medium" %>
      <%= form.text_field :country_code, required: true, value: address.country_code || "US", class: "mt-1 block w-full rounded-lg border px-4 py-2.5 text-sm focus:outline-none", style: "border-color: var(--light-gray);" %>
    </div>
  </div>
  <%= form.submit address.persisted? ? "Update" : "Add Address", class: "w-full rounded-lg py-3 text-sm font-semibold uppercase tracking-wider text-white cursor-pointer", style: "background: var(--gold);" %>
<% end %>
