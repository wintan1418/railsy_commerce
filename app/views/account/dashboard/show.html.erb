<div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
  <!-- Welcome -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">My Account</p>
      <h1 class="mt-1 font-display text-3xl font-light tracking-tight" style="color: var(--black);">Welcome back, <em class="italic"><%= current_user.first_name %></em></h1>
    </div>
    <%= link_to edit_account_address_path(current_user.addresses.first || 0), class: "hidden" do %><% end %>
  </div>

  <!-- Stats -->
  <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
      <p class="text-2xl font-bold" style="color: var(--black);"><%= @total_orders %></p>
      <p class="mt-1 text-xs font-medium uppercase tracking-wider" style="color: var(--mid-gray);">Orders</p>
    </div>
    <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
      <p class="text-2xl font-bold" style="color: var(--black);"><%= Money.new(@total_spent, "USD").format %></p>
      <p class="mt-1 text-xs font-medium uppercase tracking-wider" style="color: var(--mid-gray);">Total Spent</p>
    </div>
    <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
      <p class="text-2xl font-bold" style="color: var(--black);"><%= @wishlist_count %></p>
      <p class="mt-1 text-xs font-medium uppercase tracking-wider" style="color: var(--mid-gray);">Wishlist Items</p>
    </div>
    <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
      <p class="text-2xl font-bold" style="color: var(--black);"><%= current_user.addresses.count %></p>
      <p class="mt-1 text-xs font-medium uppercase tracking-wider" style="color: var(--mid-gray);">Addresses</p>
    </div>
  </div>

  <!-- Quick Links -->
  <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <% [
      { label: "My Orders", path: account_orders_path, icon: "M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z" },
      { label: "Wishlist", path: account_wishlist_path, icon: "M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" },
      { label: "Addresses", path: account_addresses_path, icon: "M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" },
      { label: "Profile", path: account_profile_path, icon: "M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" }
    ].each do |link| %>
      <%= link_to link[:path], class: "flex flex-col items-center gap-2 rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5" do %>
        <svg class="h-6 w-6" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="<%= link[:icon] %>" />
        </svg>
        <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--black);"><%= link[:label] %></span>
      <% end %>
    <% end %>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-3">
    <!-- Recent Orders -->
    <div class="lg:col-span-2 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
      <div class="flex items-center justify-between border-b px-6 py-4" style="border-color: var(--cream);">
        <h2 class="text-base font-semibold" style="color: var(--black);">Recent Orders</h2>
        <%= link_to "View All", account_orders_path, class: "text-sm font-medium", style: "color: var(--gold);" %>
      </div>
      <% if @orders.any? %>
        <div class="divide-y" style="border-color: var(--cream);">
          <% @orders.each do |order| %>
            <div class="flex items-center justify-between px-6 py-4">
              <div>
                <p class="text-sm font-semibold" style="color: var(--black);"><%= order.number %></p>
                <p class="mt-0.5 text-xs" style="color: var(--mid-gray);"><%= order.created_at.strftime("%B %d, %Y") %> &middot; <%= order.order_items.count %> items</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-semibold" style="color: var(--black);"><%= order.total.format %></p>
                <span class="mt-0.5 inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold capitalize" style="background: rgba(201,169,110,0.1); color: var(--gold);"><%= order.status %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-10 text-center">
          <p class="text-sm" style="color: var(--mid-gray);">No orders yet.</p>
          <%= link_to "Start Shopping", products_path, class: "mt-2 inline-block text-sm font-medium", style: "color: var(--gold);" %>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Saved Addresses -->
      <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
        <div class="flex items-center justify-between border-b px-6 py-4" style="border-color: var(--cream);">
          <h2 class="text-base font-semibold" style="color: var(--black);">Addresses</h2>
          <%= link_to "Manage", account_addresses_path, class: "text-xs font-medium", style: "color: var(--gold);" %>
        </div>
        <div class="px-6 py-4">
          <% if @addresses.any? %>
            <% @addresses.each do |addr| %>
              <div class="mb-3 last:mb-0">
                <p class="text-sm font-medium" style="color: var(--black);"><%= addr.full_name %></p>
                <p class="text-xs" style="color: var(--mid-gray);"><%= addr.one_line %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm" style="color: var(--mid-gray);">No saved addresses.</p>
            <%= link_to "Add Address", new_account_address_path, class: "mt-1 inline-block text-xs font-medium", style: "color: var(--gold);" %>
          <% end %>
        </div>
      </div>

      <!-- Track Order -->
      <div class="overflow-hidden rounded-xl shadow-sm ring-1 ring-gray-900/5 p-6" style="background: var(--black);">
        <svg class="h-8 w-8" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-white">Track Your Order</h3>
        <p class="mt-1 text-xs text-white/40">Enter your order number to see real-time delivery updates.</p>
        <%= link_to "Track Now", track_search_path, class: "mt-4 inline-block rounded-lg px-4 py-2 text-xs font-semibold uppercase tracking-wider", style: "background: var(--gold); color: var(--black);" %>
      </div>
    </div>
  </div>
</div>
