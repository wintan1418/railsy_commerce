<div class="flex min-h-[calc(100vh-5.25rem)] w-full">
  <!-- Left Panel: Branding -->
  <div class="hidden lg:flex lg:w-5/12 relative overflow-hidden" style="background: var(--black);">
    <!-- Background image -->
    <img src="https://images.unsplash.com/photo-1472851294608-062f824d29cc?w=1200&q=80" alt="" class="absolute inset-0 h-full w-full object-cover opacity-25">
    <!-- Gradient overlay -->
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(10,10,10,0.7) 0%, rgba(10,10,10,0.85) 50%, rgba(10,10,10,0.95) 100%);"></div>
    <!-- Grain -->
    <div class="absolute inset-0 grain-overlay opacity-20"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col justify-between p-12">
      <!-- Logo -->
      <div class="flex items-center gap-2.5">
        <%= link_to root_path, class: "flex items-center gap-2.5" do %>
          <div class="flex h-8 w-8 items-center justify-center rounded" style="background: rgba(201,169,110,0.15);">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none">
              <rect x="2" y="2" width="7" height="7" rx="1" fill="var(--gold)"/>
              <rect x="11" y="2" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.7"/>
              <rect x="2" y="11" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.7"/>
              <rect x="11" y="11" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.4"/>
            </svg>
          </div>
          <span class="font-display text-lg font-semibold text-white">RailsyCommerce</span>
        <% end %>
      </div>

      <!-- Motivational text -->
      <div>
        <h2 class="font-display text-4xl font-light text-white leading-tight">
          Join the<br><em class="italic" style="color: var(--gold);">Community</em>
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-white/40 max-w-sm">
          Create your free account and unlock access to exclusive deals, order tracking, wishlists, and personalized recommendations.
        </p>

        <!-- Benefits -->
        <div class="mt-8 space-y-3">
          <% [
            "Access exclusive member-only deals",
            "Track orders in real-time",
            "Save items to your wishlist",
            "Faster checkout experience"
          ].each do |benefit| %>
            <div class="flex items-center gap-3">
              <div class="flex h-5 w-5 items-center justify-center rounded-full flex-shrink-0" style="background: rgba(201,169,110,0.15);">
                <svg class="h-3 w-3" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <span class="text-xs text-white/40"><%= benefit %></span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Bottom -->
      <div class="border-t pt-6" style="border-color: rgba(255,255,255,0.08);">
        <p class="text-xs text-white/20">&copy; <%= Date.current.year %> RailsyCommerce. All rights reserved.</p>
      </div>
    </div>
  </div>

  <!-- Right Panel: Form -->
  <div class="flex flex-1 items-center justify-center px-6 py-12 sm:px-8 lg:px-16" style="background: var(--warm-white);">
    <div class="w-full max-w-md">
      <!-- Mobile logo -->
      <div class="mb-8 text-center lg:hidden">
        <%= link_to root_path, class: "inline-flex items-center gap-2.5" do %>
          <div class="flex h-8 w-8 items-center justify-center rounded" style="background: var(--black);">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none">
              <rect x="2" y="2" width="7" height="7" rx="1" fill="var(--gold)"/>
              <rect x="11" y="2" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.7"/>
              <rect x="2" y="11" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.7"/>
              <rect x="11" y="11" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.4"/>
            </svg>
          </div>
          <span class="font-display text-xl font-semibold" style="color: var(--black);">RailsyCommerce</span>
        <% end %>
      </div>

      <!-- Header -->
      <div>
        <h1 class="font-display text-3xl font-light tracking-tight" style="color: var(--black);">Create <em class="italic" style="color: var(--gold);">Account</em></h1>
        <p class="mt-2 text-sm" style="color: var(--mid-gray);">
          Already have an account?
          <%= link_to "Sign in", new_session_path, class: "font-semibold transition-colors duration-200 hover:opacity-70", style: "color: var(--gold);" %>
        </p>
      </div>

      <!-- Google Sign-Up -->
      <div class="mt-8">
        <%= form_with url: "/auth/google_oauth2", method: :post, data: { turbo: false } do %>
          <button type="submit" class="flex w-full items-center justify-center gap-3 rounded-lg border px-4 py-3 text-sm font-medium transition-all duration-200 hover:shadow-md cursor-pointer" style="border-color: var(--cream); color: var(--black); background: white;">
            <svg class="h-5 w-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Continue with Google
          </button>
        <% end %>
      </div>

      <!-- Divider -->
      <div class="relative mt-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full" style="height: 1px; background: var(--cream);"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-4 text-xs uppercase tracking-wider" style="background: var(--warm-white); color: var(--mid-gray);">or register with email</span>
        </div>
      </div>

      <!-- Form -->
      <%= form_with model: @user, url: registration_path, class: "mt-6 space-y-4" do |form| %>
        <% if @user.errors.any? %>
          <div class="rounded-lg px-4 py-3 border" style="background: rgba(192,57,43,0.05); border-color: rgba(192,57,43,0.15);">
            <ul class="list-disc list-inside text-sm space-y-1" style="color: var(--red);">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Role Selection -->
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--text-body);">I want to</label>
          <div class="grid grid-cols-2 gap-3">
            <label class="relative cursor-pointer">
              <%= form.radio_button :role, "customer", class: "peer sr-only", checked: true %>
              <div class="rounded-lg border-2 p-4 text-center transition-all duration-200 peer-checked:border-[var(--gold)] peer-checked:bg-[rgba(201,169,110,0.05)]" style="border-color: var(--cream);">
                <svg class="mx-auto h-6 w-6 mb-2" style="color: var(--mid-gray);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z" /></svg>
                <p class="text-sm font-semibold" style="color: var(--black);">Shop</p>
                <p class="text-[11px] mt-0.5" style="color: var(--mid-gray);">Buy products</p>
              </div>
            </label>
            <label class="relative cursor-pointer">
              <%= form.radio_button :role, "vendor", class: "peer sr-only" %>
              <div class="rounded-lg border-2 p-4 text-center transition-all duration-200 peer-checked:border-[var(--gold)] peer-checked:bg-[rgba(201,169,110,0.05)]" style="border-color: var(--cream);">
                <svg class="mx-auto h-6 w-6 mb-2" style="color: var(--mid-gray);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0021 9.349m-18 0a2.999 2.999 0 00.75-1.974V5.25A2.25 2.25 0 016 3h12a2.25 2.25 0 012.25 2.25v2.125a3 3 0 01-.75 1.974" /></svg>
                <p class="text-sm font-semibold" style="color: var(--black);">Sell</p>
                <p class="text-[11px] mt-0.5" style="color: var(--mid-gray);">List & sell products</p>
              </div>
            </label>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= form.label :first_name, class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
            <%= form.text_field :first_name, required: true, autofocus: true, autocomplete: "given-name",
              class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
              style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
              placeholder: "First" %>
          </div>
          <div>
            <%= form.label :last_name, class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
            <%= form.text_field :last_name, required: true, autocomplete: "family-name",
              class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
              style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
              placeholder: "Last" %>
          </div>
        </div>

        <div>
          <%= form.label :email_address, "Email address", class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
          <%= form.email_field :email_address, required: true, autocomplete: "email",
            class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
            style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
            placeholder: "you@example.com" %>
        </div>

        <div>
          <%= form.label :password, class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password",
            class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
            style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
            placeholder: "At least 8 characters" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm password", class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
            style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
            placeholder: "Repeat your password" %>
        </div>

        <!-- Vendor Fields (shown via JS when vendor role selected) -->
        <div id="vendor-fields" class="space-y-4 hidden">
          <div class="rounded-lg p-4" style="background: rgba(201,169,110,0.05); border: 1px solid rgba(201,169,110,0.2);">
            <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--gold);">Business Details</p>
            <div>
              <%= form.label :vendor_name, "Business / Store Name", class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
              <%= form.text_field :vendor_name,
                class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
                style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
                placeholder: "Your business name" %>
            </div>
            <div class="mt-3">
              <%= form.label :phone, "Phone Number", class: "block text-xs font-semibold uppercase tracking-wider", style: "color: var(--text-body);" %>
              <%= form.telephone_field :phone,
                class: "mt-2 block w-full rounded-lg border px-4 py-3 text-sm transition-all duration-200 focus:outline-none focus:ring-2",
                style: "border-color: var(--cream); color: var(--black); background: white; --tw-ring-color: var(--gold);",
                placeholder: "+234 800 000 0000" %>
            </div>
          </div>
        </div>

        <script>
          document.querySelectorAll('input[name="user[role]"]').forEach(radio => {
            radio.addEventListener('change', () => {
              document.getElementById('vendor-fields').classList.toggle('hidden', radio.value !== 'vendor')
            })
          })
        </script>

        <%= form.submit "Create account",
          class: "w-full rounded-lg py-3 text-sm font-semibold uppercase tracking-wider shadow-sm transition-all duration-200 hover:opacity-90 hover:shadow-md cursor-pointer",
          style: "background: var(--gold); color: var(--black);" %>
      <% end %>

      <p class="mt-6 text-center text-xs" style="color: var(--mid-gray);">
        By creating an account, you agree to our
        <a href="#" class="underline transition-colors hover:opacity-70" style="color: var(--text-body);">Terms</a> and
        <a href="#" class="underline transition-colors hover:opacity-70" style="color: var(--text-body);">Privacy Policy</a>.
      </p>
    </div>
  </div>
</div>
