<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Last 30 days overview</p>
  </div>
  <span class="text-sm text-gray-400"><%= Date.current.strftime("%B %d, %Y") %></span>
</div>

<!-- Stat Cards -->
<div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
  <div class="overflow-hidden rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-sm font-medium text-gray-500">Revenue</p>
    <p class="mt-2 text-2xl font-bold text-gray-900"><%= Money.new(@data[:total_revenue], "USD").format %></p>
  </div>
  <div class="overflow-hidden rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-sm font-medium text-gray-500">Orders</p>
    <p class="mt-2 text-2xl font-bold text-gray-900"><%= @data[:order_count] %></p>
  </div>
  <div class="overflow-hidden rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-sm font-medium text-gray-500">Avg. Order Value</p>
    <p class="mt-2 text-2xl font-bold text-gray-900"><%= Money.new(@data[:average_order_value], "USD").format %></p>
  </div>
  <div class="overflow-hidden rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-sm font-medium text-gray-500">New Customers</p>
    <p class="mt-2 text-2xl font-bold text-gray-900"><%= @data[:customer_count] %></p>
  </div>
</div>

<!-- Charts -->
<div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3"
     data-controller="admin-chart"
     data-admin-chart-revenue-data-value="<%= @data[:revenue_by_day].to_json %>"
     data-admin-chart-status-data-value="<%= @data[:orders_by_status].to_json %>">
  <!-- Revenue Chart -->
  <div class="lg:col-span-2 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Revenue (Last 30 Days)</h2>
    </div>
    <div class="p-6" style="height: 300px;">
      <canvas data-admin-chart-target="revenueCanvas"></canvas>
    </div>
  </div>

  <!-- Orders by Status Doughnut -->
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Orders by Status</h2>
    </div>
    <div class="p-6" style="height: 300px;">
      <canvas data-admin-chart-target="statusCanvas"></canvas>
    </div>
  </div>
</div>

<!-- Orders by Status Counts -->
<div class="mt-8">
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="grid grid-cols-3 gap-4 p-6 sm:grid-cols-6">
      <% @data[:orders_by_status].each do |status, count| %>
        <div class="text-center">
          <p class="text-2xl font-bold text-gray-900"><%= count %></p>
          <p class="mt-1 text-xs capitalize text-gray-500"><%= status %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
  <!-- Top Products -->
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Top Products</h2>
    </div>
    <div class="divide-y divide-gray-100">
      <% @data[:top_products].each_with_index do |product, i| %>
        <div class="flex items-center gap-3 px-6 py-3">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-gray-100 text-xs font-bold text-gray-500"><%= i + 1 %></span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-medium text-gray-900"><%= product.name %></p>
            <p class="text-xs text-gray-500"><%= product.total_sold %> sold</p>
          </div>
        </div>
      <% end %>
      <% if @data[:top_products].empty? %>
        <p class="px-6 py-8 text-center text-sm text-gray-400">No sales data yet</p>
      <% end %>
    </div>
  </div>

  <!-- Recent Orders -->
  <div class="lg:col-span-2 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Recent Orders</h2>
      <%= link_to "View all", admin_orders_path, class: "text-sm font-medium", style: "color: var(--gold);" %>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-100">
        <thead><tr class="bg-gray-50/50">
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase text-gray-500">Order</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase text-gray-500">Customer</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase text-gray-500">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase text-gray-500">Total</th>
        </tr></thead>
        <tbody class="divide-y divide-gray-100">
          <% @data[:recent_orders].each do |order| %>
            <tr class="hover:bg-gray-50/50">
              <td class="px-6 py-4 text-sm"><%= link_to order.number, admin_order_path(order), class: "font-semibold", style: "color: var(--gold);" %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= order.email %></td>
              <td class="px-6 py-4"><span class="rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize bg-gray-100 text-gray-700"><%= order.status %></span></td>
              <td class="px-6 py-4 text-sm font-medium"><%= order.total.format %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Low Stock -->
<div class="mt-8">
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Low Stock Alerts</h2>
    </div>
    <div class="divide-y divide-gray-100">
      <% if @data[:low_stock_items].any? %>
        <% @data[:low_stock_items].each do |item| %>
          <div class="flex items-center justify-between px-6 py-3">
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-gray-900"><%= item.variant.product.name %></p>
              <p class="text-xs text-gray-500"><%= item.variant.sku %></p>
            </div>
            <span class="rounded-full px-2 py-0.5 text-xs font-bold <%= item.available_quantity <= 5 ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
              <%= item.available_quantity %> left
            </span>
          </div>
        <% end %>
      <% else %>
        <p class="px-6 py-8 text-center text-sm text-gray-400">All products well stocked</p>
      <% end %>
    </div>
  </div>
</div>
