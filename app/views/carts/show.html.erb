<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <h1 class="text-3xl font-bold tracking-tight text-gray-900">Shopping Cart</h1>

  <% if current_cart.empty? %>
    <!-- Empty Cart State -->
    <div class="mt-16 flex flex-col items-center text-center">
      <div class="flex h-24 w-24 items-center justify-center rounded-full bg-gray-100">
        <svg class="h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
        </svg>
      </div>
      <h2 class="mt-6 text-xl font-semibold text-gray-900">Your cart is empty</h2>
      <p class="mt-2 text-sm text-gray-500 max-w-sm">Looks like you haven't added any items to your cart yet. Browse our collection and find something you love.</p>
      <div class="mt-8">
        <%= link_to "Continue Shopping", products_path,
          class: "rounded-full bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 transition-colors duration-200" %>
      </div>
    </div>
  <% else %>
    <div class="mt-10 lg:grid lg:grid-cols-12 lg:gap-x-12">
      <!-- Cart Items -->
      <div class="lg:col-span-7">
        <div class="divide-y divide-gray-200" id="cart-items">
          <% current_cart.cart_items.includes(variant: { product: { images_attachments: :blob } }).each do |item| %>
            <%= render "cart_items/cart_item", cart_item: item %>
          <% end %>
        </div>

        <div class="mt-6">
          <%= link_to products_path, class: "inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors duration-200" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
            Continue Shopping
          <% end %>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="mt-10 lg:col-span-5 lg:mt-0">
        <div class="sticky top-24 rounded-2xl bg-gray-50 p-8">
          <h2 class="text-lg font-semibold text-gray-900">Order Summary</h2>

          <dl class="mt-6 space-y-4">
            <div class="flex justify-between">
              <dt class="text-sm text-gray-600">Subtotal (<%= current_cart.item_count %> items)</dt>
              <dd class="text-sm font-medium text-gray-900"><%= current_cart.subtotal.format %></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-gray-600">Estimated Shipping</dt>
              <dd class="text-sm font-medium text-gray-900">
                <% if current_cart.subtotal.to_f >= 50 %>
                  <span class="text-green-600">Free</span>
                <% else %>
                  $9.99
                <% end %>
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-gray-600">Estimated Tax</dt>
              <dd class="text-sm font-medium text-gray-500">Calculated at checkout</dd>
            </div>
            <div class="border-t border-gray-200 pt-4 flex justify-between">
              <dt class="text-base font-semibold text-gray-900">Estimated Total</dt>
              <dd class="text-base font-semibold text-gray-900"><%= current_cart.subtotal.format %></dd>
            </div>
          </dl>

          <div class="mt-8">
            <button type="button" class="w-full rounded-lg bg-indigo-600 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 transition-colors duration-200 cursor-pointer">
              Proceed to Checkout
            </button>
          </div>

          <!-- Trust Badges -->
          <div class="mt-6 flex items-center justify-center gap-4 border-t border-gray-200 pt-6">
            <div class="flex items-center gap-1.5 text-gray-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              <span class="text-xs">Secure checkout</span>
            </div>
            <div class="flex items-center gap-1.5 text-gray-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
              <span class="text-xs">Free returns</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
