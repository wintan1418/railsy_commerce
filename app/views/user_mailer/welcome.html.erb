<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; background-color: #faf9f6; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #faf9f6;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding-bottom: 32px;">
              <h1 style="margin: 0; font-family: Georgia, 'Times New Roman', serif; font-size: 28px; font-weight: 600; color: #1a1a1a; letter-spacing: -0.5px;">RailsyCommerce</h1>
            </td>
          </tr>

          <!-- Main Content -->
          <tr>
            <td style="background-color: #ffffff; border-radius: 12px; padding: 40px; border: 1px solid #e8e5e0;">

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding-bottom: 32px;">
                    <h2 style="margin: 0; font-family: Georgia, 'Times New Roman', serif; font-size: 28px; font-weight: 600; color: #1a1a1a;">Welcome, <%= @user.first_name %></h2>
                  </td>
                </tr>
                <tr>
                  <td style="padding-bottom: 24px;">
                    <p style="margin: 0; font-size: 15px; color: #555555; line-height: 1.7;">
                      Thank you for creating your RailsyCommerce account. We're delighted to have you join our community of discerning shoppers.
                    </p>
                  </td>
                </tr>
                <tr>
                  <td style="padding-bottom: 24px;">
                    <p style="margin: 0; font-size: 15px; color: #555555; line-height: 1.7;">
                      With your account, you can:
                    </p>
                  </td>
                </tr>
                <tr>
                  <td style="padding-bottom: 32px;">
                    <table role="presentation" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #555555;">
                          <span style="color: #c9a96e; font-weight: bold; margin-right: 8px;">&#8226;</span>
                          Track your orders in real-time
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #555555;">
                          <span style="color: #c9a96e; font-weight: bold; margin-right: 8px;">&#8226;</span>
                          Save your shipping addresses for faster checkout
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #555555;">
                          <span style="color: #c9a96e; font-weight: bold; margin-right: 8px;">&#8226;</span>
                          Create wishlists of your favorite items
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; font-size: 14px; color: #555555;">
                          <span style="color: #c9a96e; font-weight: bold; margin-right: 8px;">&#8226;</span>
                          Leave reviews on products you love
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td align="center">
                    <a href="<%= root_url %>" style="display: inline-block; background-color: #c9a96e; color: #ffffff; font-size: 14px; font-weight: 600; text-decoration: none; padding: 14px 32px; border-radius: 8px; text-transform: uppercase; letter-spacing: 1px;">
                      Start Shopping
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding-top: 32px;">
              <p style="margin: 0; font-size: 12px; color: #888888;">
                Need help? Reply to this email or contact us at support@railsycommerce.com
              </p>
              <p style="margin: 8px 0 0; font-size: 12px; color: #cccccc;">
                &copy; <%= Date.current.year %> RailsyCommerce. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
