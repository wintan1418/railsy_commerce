<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Import Products</h1>
    <p class="mt-1 text-sm text-gray-500">Upload a CSV file to bulk import products</p>
  </div>
  <%= link_to "Back to Products", admin_products_path,
    class: "rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-gray-200 hover:bg-gray-50 transition-colors duration-200" %>
</div>

<div class="mt-8 max-w-2xl">
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
    <div class="p-6">
      <%= form_with url: admin_import_path, method: :post, multipart: true do |form| %>
        <div class="space-y-6">
          <!-- File Upload -->
          <div>
            <label class="block text-sm font-medium text-gray-700">CSV File</label>
            <div class="mt-2">
              <%= file_field_tag :file, accept: ".csv",
                class: "block w-full text-sm text-gray-500 file:mr-4 file:rounded-lg file:border-0 file:bg-indigo-50 file:px-4 file:py-2.5 file:text-sm file:font-semibold file:text-indigo-700 hover:file:bg-indigo-100 file:cursor-pointer" %>
            </div>
            <p class="mt-2 text-xs text-gray-500">Upload a .csv file with product data. Maximum 1000 rows recommended.</p>
          </div>

          <!-- Expected Format -->
          <div class="rounded-lg bg-gray-50 p-4">
            <h3 class="text-sm font-semibold text-gray-700">Expected CSV Columns</h3>
            <div class="mt-2 overflow-x-auto">
              <table class="text-xs text-gray-600">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="py-1 pr-4 text-left font-semibold">Column</th>
                    <th class="py-1 pr-4 text-left font-semibold">Required</th>
                    <th class="py-1 text-left font-semibold">Example</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <tr><td class="py-1 pr-4 font-mono">name</td><td class="pr-4">Yes</td><td>Classic T-Shirt</td></tr>
                  <tr><td class="py-1 pr-4 font-mono">description</td><td class="pr-4">No</td><td>A comfortable cotton tee</td></tr>
                  <tr><td class="py-1 pr-4 font-mono">category</td><td class="pr-4">No</td><td>Clothing</td></tr>
                  <tr><td class="py-1 pr-4 font-mono">price</td><td class="pr-4">No</td><td>29.99</td></tr>
                  <tr><td class="py-1 pr-4 font-mono">sku</td><td class="pr-4">No</td><td>TSH-001</td></tr>
                  <tr><td class="py-1 pr-4 font-mono">status</td><td class="pr-4">No</td><td>draft / active / archived</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Download Template -->
          <div>
            <%= link_to "/sample_product_import.csv", class: "inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-500" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download sample CSV template
            <% end %>
          </div>

          <!-- Submit -->
          <div class="flex justify-end">
            <%= form.submit "Import Products",
              class: "rounded-lg bg-indigo-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 transition-colors duration-200 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
