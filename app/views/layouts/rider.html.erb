<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Rider Dashboard - RailsyCommerce" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full antialiased" style="background: var(--warm-white);">
    <!-- Top Nav (mobile-friendly, no sidebar) -->
    <nav class="sticky top-0 z-50 border-b" style="background: var(--black); border-color: rgba(255,255,255,0.1);">
      <div class="mx-auto max-w-3xl px-4 py-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-full" style="background: var(--gold);">
              <svg class="h-4 w-4" style="color: var(--black);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
            </div>
            <span class="text-sm font-bold text-white">Rider Portal</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-white/50"><%= current_user&.first_name %></span>
            <%= button_to session_path, method: :delete, class: "text-xs text-white/40 hover:text-white cursor-pointer" do %>Sign out<% end %>
          </div>
        </div>
        <!-- Tab Nav -->
        <div class="mt-3 flex gap-1">
          <%= link_to "Home", rider_root_path,
            class: "flex-1 rounded-lg py-2 text-center text-xs font-semibold transition-colors #{request.path == rider_root_path ? 'text-white' : 'text-white/40'}",
            style: request.path == rider_root_path ? "background: rgba(255,255,255,0.1);" : "" %>
          <%= link_to "Available", rider_deliveries_path(filter: "available"),
            class: "flex-1 rounded-lg py-2 text-center text-xs font-semibold transition-colors #{params[:filter] == 'available' ? 'text-white' : 'text-white/40'}",
            style: params[:filter] == "available" ? "background: rgba(255,255,255,0.1);" : "" %>
          <%= link_to "Active", rider_deliveries_path(filter: "active"),
            class: "flex-1 rounded-lg py-2 text-center text-xs font-semibold transition-colors #{params[:filter] == 'active' ? 'text-white' : 'text-white/40'}",
            style: params[:filter] == "active" ? "background: rgba(255,255,255,0.1);" : "" %>
          <%= link_to "Done", rider_deliveries_path(filter: "completed"),
            class: "flex-1 rounded-lg py-2 text-center text-xs font-semibold transition-colors #{params[:filter] == 'completed' ? 'text-white' : 'text-white/40'}",
            style: params[:filter] == "completed" ? "background: rgba(255,255,255,0.1);" : "" %>
        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="mx-auto max-w-3xl px-4 mt-3">
        <div class="rounded-lg px-4 py-3" style="background: rgba(201,169,110,0.1); border: 1px solid rgba(201,169,110,0.2);">
          <p class="text-sm" style="color: var(--gold);"><%= flash[:notice] %></p>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mx-auto max-w-3xl px-4 mt-3">
        <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm text-red-800"><%= flash[:alert] %></p>
        </div>
      </div>
    <% end %>

    <main class="mx-auto max-w-3xl px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
