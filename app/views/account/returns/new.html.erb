<div class="mx-auto max-w-3xl px-6 py-12">
  <nav class="flex items-center gap-2 text-sm mb-8" style="color: var(--mid-gray);">
    <%= link_to "My Orders", account_orders_path, class: "transition-colors duration-200 hover:text-[var(--gold)]" %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <%= link_to @order.number, account_order_path(@order), class: "transition-colors duration-200 hover:text-[var(--gold)]" %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <span style="color: var(--black);">Request Return</span>
  </nav>

  <h1 class="font-display text-3xl font-light" style="color: var(--black);">Request a Return</h1>
  <p class="mt-2 text-sm" style="color: var(--mid-gray);">Order <%= @order.number %></p>

  <% if @return_request.errors.any? %>
    <div class="mt-6 rounded-lg border px-4 py-3" style="border-color: var(--red); background: #fef2f2;">
      <ul class="text-sm" style="color: var(--red);">
        <% @return_request.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @return_request, url: account_order_returns_path(@order), class: "mt-8 space-y-6" do |form| %>
    <div>
      <label class="block text-sm font-semibold mb-2" style="color: var(--black);">Reason for Return</label>
      <%= form.text_area :reason, rows: 4, required: true,
        class: "w-full rounded-lg border px-4 py-3 text-sm focus:outline-none focus:ring-2",
        style: "border-color: var(--cream); color: var(--black); --tw-ring-color: var(--gold);",
        placeholder: "Please describe why you'd like to return this item..." %>
    </div>

    <div>
      <label class="block text-sm font-semibold mb-2" style="color: var(--black);">Additional Notes (optional)</label>
      <%= form.text_area :notes, rows: 2,
        class: "w-full rounded-lg border px-4 py-3 text-sm focus:outline-none focus:ring-2",
        style: "border-color: var(--cream); color: var(--black); --tw-ring-color: var(--gold);" %>
    </div>

    <div>
      <label class="block text-sm font-semibold mb-4" style="color: var(--black);">Items to Return</label>
      <div class="space-y-3">
        <% @order_items.each_with_index do |item, index| %>
          <div class="flex items-center justify-between rounded-lg border p-4" style="border-color: var(--cream);">
            <div class="flex items-center gap-4">
              <div>
                <p class="text-sm font-medium" style="color: var(--black);"><%= item.variant.product.name %></p>
                <p class="text-xs" style="color: var(--mid-gray);">Qty ordered: <%= item.quantity %> | <%= item.total.format %></p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <%= form.fields_for :return_items, ReturnItem.new do |ri| %>
                <% if ri.index == index %>
                  <%= ri.hidden_field :order_item_id, value: item.id %>
                  <%= ri.number_field :quantity, value: item.quantity, min: 0, max: item.quantity,
                    class: "w-16 rounded-lg border px-3 py-2 text-center text-sm focus:outline-none focus:ring-2",
                    style: "border-color: var(--cream); --tw-ring-color: var(--gold);" %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="pt-4">
      <%= form.submit "Submit Return Request",
        class: "w-full rounded-lg py-3.5 text-sm font-semibold uppercase tracking-wider text-white shadow-sm transition-all duration-200 cursor-pointer",
        style: "background: var(--black);",
        onmouseover: "this.style.background='var(--gold)'; this.style.color='var(--black)';",
        onmouseout: "this.style.background='var(--black)'; this.style.color='white';" %>
    </div>
  <% end %>
</div>
