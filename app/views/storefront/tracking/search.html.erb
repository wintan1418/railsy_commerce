<div class="mx-auto max-w-2xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Order Tracking</p>
    <h1 class="mt-2 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">Track Your <em class="italic">Order</em></h1>
    <p class="mt-4 text-sm" style="color: var(--mid-gray);">Enter your order number or tracking number to see real-time delivery updates.</p>
  </div>

  <%= form_with url: tracking_path, method: :get, class: "mt-10" do |f| %>
    <div class="flex gap-3">
      <input type="text" name="tracking_number" required placeholder="Order number (e.g., RC-20260324-ABC123)" autofocus
        class="flex-1 rounded-lg border px-4 py-3.5 text-sm focus:outline-none focus:ring-2 min-h-[48px]"
        style="border-color: var(--cream); color: var(--black); --tw-ring-color: var(--gold);">
      <button type="submit" class="rounded-lg px-8 py-3.5 text-sm font-semibold uppercase tracking-wider min-h-[48px] cursor-pointer"
        style="background: var(--gold); color: var(--black);">
        Track
      </button>
    </div>
  <% end %>
</div>
