<div style="background: var(--warm-white);">
  <!-- ═══════════════════════════════════════════════════════════════════
       HERO - Cinematic with Image Slideshow & Product Previews
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="height: 88vh; min-height: 640px; max-height: 1050px; background: var(--black);"
           data-controller="slideshow" data-slideshow-interval-value="4500"
           data-action="mouseenter->slideshow#pause mouseleave->slideshow#resume">

    <!-- Background image slideshow -->
    <% hero_images = [
      "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1920&q=80",
      "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=1920&q=80",
      "https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=1920&q=80",
      "https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?w=1920&q=80"
    ] %>
    <% hero_images.each_with_index do |img, i| %>
      <div data-slideshow-target="slide" class="absolute inset-0 <%= i == 0 ? 'slide-active' : 'slide-inactive' %>">
        <img src="<%= img %>" alt="" class="h-full w-full object-cover object-center hero-slide-img" loading="<%= i == 0 ? 'eager' : 'lazy' %>">
      </div>
    <% end %>

    <!-- Dark gradient overlays -->
    <div class="absolute inset-0 z-10" style="background: linear-gradient(100deg, rgba(8,8,8,0.92) 0%, rgba(8,8,8,0.7) 35%, rgba(8,8,8,0.4) 60%, rgba(8,8,8,0.25) 100%);"></div>
    <div class="absolute inset-0 z-10" style="background: linear-gradient(0deg, rgba(8,8,8,0.6) 0%, transparent 30%, transparent 85%, rgba(8,8,8,0.35) 100%);"></div>

    <!-- Grain texture -->
    <div class="absolute inset-0 z-10 grain-overlay opacity-30"></div>

    <!-- Hero content: text + floating product cards -->
    <div class="relative z-20 mx-auto flex h-full max-w-7xl items-center px-6 sm:px-8 lg:px-12">
      <!-- Left: Main text -->
      <div class="max-w-xl" style="animation: heroIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
        <!-- Eyebrow -->
        <div class="flex items-center gap-4">
          <span class="block h-px" style="background: var(--gold); animation: heroLineExpand 1s ease-out 0.5s both;"></span>
          <span class="text-xs font-medium uppercase tracking-[0.35em]" style="color: var(--gold);">Premium Marketplace</span>
        </div>

        <!-- Title -->
        <h1 class="mt-7 font-display font-light leading-[1.05] tracking-tight text-white" style="font-size: clamp(3rem, 5vw, 5.5rem);">
          Discover<br>
          What's <em class="font-display italic shimmer-gold">Next</em>
        </h1>

        <!-- Subtitle -->
        <p class="mt-5 max-w-md text-[15px] leading-relaxed" style="color: rgba(255,255,255,0.5);">
          From cutting-edge tech to timeless home essentials — everything you need, beautifully curated and delivered to your door.
        </p>

        <!-- CTAs -->
        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <%= link_to products_path, class: "group inline-flex items-center justify-center gap-3 px-10 py-4 text-sm font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:opacity-90", style: "background: var(--gold); color: var(--black);" do %>
            Shop Now
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
          <%= link_to "Explore Categories", "#categories",
            class: "inline-flex items-center justify-center gap-3 border px-10 py-4 text-sm font-semibold uppercase tracking-[0.15em] text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/10",
            style: "border-color: rgba(255,255,255,0.25);" %>
        </div>

        <!-- Quick category pills -->
        <div class="mt-8 flex flex-wrap gap-2">
          <% %w[Electronics Fashion Home Sports Beauty].each do |cat_name| %>
            <span class="rounded-full border px-3 py-1 text-[10px] font-medium uppercase tracking-wider text-white/40 transition-colors duration-200 hover:border-[var(--gold)] hover:text-[var(--gold)] cursor-pointer" style="border-color: rgba(255,255,255,0.12);">
              <%= cat_name %>
            </span>
          <% end %>
        </div>
      </div>

      <!-- Right: Floating product preview cards (desktop only) -->
      <div class="hidden lg:block absolute right-12 top-1/2 -translate-y-1/2" style="animation: heroIn 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
        <div class="relative" style="width: 380px; height: 420px;">
          <!-- Card 1: Top right -->
          <div class="absolute top-0 right-0 rounded-2xl overflow-hidden shadow-2xl border border-white/10 animate-float" style="width: 180px; animation-delay: 0s;">
            <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&q=80" alt="Premium Watch" class="h-44 w-full object-cover">
            <div class="px-3 py-2.5" style="background: rgba(20,20,20,0.9); backdrop-filter: blur(10px);">
              <p class="text-xs font-semibold text-white truncate">Premium Watch</p>
              <p class="text-[11px] mt-0.5" style="color: var(--gold);">$249.00</p>
            </div>
          </div>

          <!-- Card 2: Bottom left -->
          <div class="absolute bottom-0 left-0 rounded-2xl overflow-hidden shadow-2xl border border-white/10 animate-float" style="width: 180px; animation-delay: 1.5s;">
            <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400&q=80" alt="Wireless Headphones" class="h-44 w-full object-cover">
            <div class="px-3 py-2.5" style="background: rgba(20,20,20,0.9); backdrop-filter: blur(10px);">
              <p class="text-xs font-semibold text-white truncate">Wireless Headphones</p>
              <p class="text-[11px] mt-0.5" style="color: var(--gold);">$179.00</p>
            </div>
          </div>

          <!-- Card 3: Middle (overlapping) -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-2xl overflow-hidden shadow-2xl border border-white/10 animate-float z-10" style="width: 170px; animation-delay: 0.8s;">
            <img src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=400&q=80" alt="Modern Lamp" class="h-40 w-full object-cover">
            <div class="px-3 py-2.5" style="background: rgba(20,20,20,0.9); backdrop-filter: blur(10px);">
              <p class="text-xs font-semibold text-white truncate">Modern Lamp</p>
              <p class="text-[11px] mt-0.5" style="color: var(--gold);">$89.00</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide indicators -->
    <div class="absolute bottom-8 left-1/2 z-30 flex -translate-x-1/2 items-center gap-2">
      <% hero_images.each_with_index do |_, i| %>
        <button data-slideshow-target="dot" data-slide-index="<%= i %>" data-action="click->slideshow#goToSlide"
                class="h-2 cursor-pointer transition-all duration-500 <%= i == 0 ? 'dot-active' : 'dot-inactive' %>"
                aria-label="Slide <%= i + 1 %>"></button>
      <% end %>
    </div>

    <!-- Bottom Right: Stats with dividers -->
    <div class="absolute bottom-12 right-12 z-20 hidden lg:flex items-center gap-8" style="animation: heroIn 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;">
      <div class="text-right">
        <p class="font-display text-2xl font-semibold" style="color: var(--gold);">5k+</p>
        <p class="text-[10px] uppercase tracking-wider" style="color: rgba(255,255,255,0.3);">Products</p>
      </div>
      <div class="h-8 w-px" style="background: rgba(255,255,255,0.08);"></div>
      <div class="text-right">
        <p class="font-display text-2xl font-semibold" style="color: var(--gold);">200+</p>
        <p class="text-[10px] uppercase tracking-wider" style="color: rgba(255,255,255,0.3);">Brands</p>
      </div>
      <div class="h-8 w-px" style="background: rgba(255,255,255,0.08);"></div>
      <div class="text-right">
        <p class="font-display text-2xl font-semibold" style="color: var(--gold);">98%</p>
        <p class="text-[10px] uppercase tracking-wider" style="color: rgba(255,255,255,0.3);">Satisfaction</p>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 right-10 z-30 hidden animate-float lg:block">
      <a href="#categories" class="flex flex-col items-center gap-2" style="color: rgba(255,255,255,0.25);">
        <span class="text-[10px] font-medium uppercase tracking-[0.3em]" style="writing-mode: vertical-rl;">Scroll</span>
        <div class="h-8 w-px overflow-hidden" style="background: rgba(255,255,255,0.08);">
          <div class="h-full w-full" style="background: var(--gold); animation: scrollAnim 2s ease-in-out infinite;"></div>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       TRUST BAR
       ═══════════════════════════════════════════════════════════════════ -->
  <section style="background: linear-gradient(180deg, var(--cream) 0%, var(--warm-white) 100%);">
    <div class="mx-auto max-w-7xl px-6 py-6 sm:px-8 lg:px-12">
      <div class="grid grid-cols-2 gap-y-4 gap-x-6 lg:grid-cols-4">
        <% [
          { icon: "M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12", label: "Free Shipping", sub: "Orders over $75" },
          { icon: "M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182", label: "Easy Returns", sub: "30-day policy" },
          { icon: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z", label: "Secure Checkout", sub: "SSL encrypted" },
          { icon: "M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155", label: "24/7 Support", sub: "Always here" }
        ].each do |item| %>
          <div class="trust-item flex items-center gap-3 cursor-default">
            <div class="flex h-10 w-10 items-center justify-center rounded-full flex-shrink-0" style="background: rgba(201,169,110,0.1);">
              <svg class="trust-icon h-5 w-5" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="<%= item[:icon] %>" />
              </svg>
            </div>
            <div>
              <span class="text-xs font-semibold uppercase tracking-wider block" style="color: var(--black);"><%= item[:label] %></span>
              <span class="text-[10px]" style="color: var(--mid-gray);"><%= item[:sub] %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       POPULAR RIGHT NOW - Products shown immediately
       ═══════════════════════════════════════════════════════════════════ -->
  <% if @popular_products.any? %>
    <section style="background: var(--warm-white);">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
        <div class="flex items-end justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Discover</p>
            <h2 class="mt-2 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">Popular <em class="italic">Right Now</em></h2>
          </div>
          <%= link_to products_path, class: "hidden items-center gap-2 text-sm font-medium transition-colors sm:flex hover:opacity-70", style: "color: var(--black);" do %>
            Shop All
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
        </div>
        <div class="mt-10 grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4 lg:gap-x-6">
          <% @popular_products.each do |product| %>
            <%= render "storefront/products/product_card", product: product %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- ═══════════════════════════════════════════════════════════════════
       TRENDING CATEGORIES - Large visual cards
       ═══════════════════════════════════════════════════════════════════ -->
  <% if @categories.any? %>
    <% category_images = {
      "Clothing" => "https://images.unsplash.com/photo-1445205170230-053b83016050?w=600&q=80",
      "Electronics" => "https://images.unsplash.com/photo-1468495244123-6c6c332eeece?w=600&q=80",
      "Home & Living" => "https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=600&q=80",
      "Sports & Outdoors" => "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=600&q=80",
      "Accessories" => "https://images.unsplash.com/photo-1523170335258-f5ed11844a49?w=600&q=80",
      "Beauty & Wellness" => "https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=600&q=80",
      "Books & Media" => "https://images.unsplash.com/photo-1512820790803-83ca734da794?w=600&q=80",
      "Groceries" => "https://images.unsplash.com/photo-1542838132-92c53300491e?w=600&q=80",
      "Toys & Games" => "https://images.unsplash.com/photo-1558060370-d644479cb6f7?w=600&q=80",
      "Automotive" => "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=600&q=80",
      "Garden & DIY" => "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&q=80",
      "Pet Supplies" => "https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=600&q=80"
    } %>
    <% fallback_images = [
      "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&q=80",
      "https://images.unsplash.com/photo-1472851294608-062f824d29cc?w=600&q=80",
      "https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&q=80",
      "https://images.unsplash.com/photo-1555529669-e69e7aa0ba9a?w=600&q=80",
      "https://images.unsplash.com/photo-1607082349566-187342175e2f?w=600&q=80",
      "https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?w=600&q=80"
    ] %>
    <% category_gradients = [
      "linear-gradient(135deg, #1a1510 0%, #0f0d0a 100%)",
      "linear-gradient(135deg, #0f1923 0%, #0a1018 100%)",
      "linear-gradient(135deg, #1c1a15 0%, #12110d 100%)",
      "linear-gradient(135deg, #0d1a12 0%, #091009 100%)",
      "linear-gradient(135deg, #1a1520 0%, #100d15 100%)",
      "linear-gradient(135deg, #1a1015 0%, #120a0f 100%)"
    ] %>
    <section id="categories" class="py-20 lg:py-28" style="background: var(--warm-white);">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
        <!-- Section header -->
        <div class="text-center max-w-2xl mx-auto">
          <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">Browse</p>
          <h2 class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl" style="color: var(--black);">Shop by <em class="italic">Category</em></h2>
          <p class="mt-4 text-sm leading-relaxed" style="color: var(--mid-gray);">Explore our diverse range of products across every category imaginable</p>
          <div class="gold-line mt-6 mx-auto w-20 opacity-40"></div>
        </div>

        <!-- Category grid: 2 large + 4 small layout -->
        <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-12 lg:auto-rows-[280px]">
          <% @categories.first(6).each_with_index do |category, idx| %>
            <%
              # First 2 categories get large cards (span 4 cols), rest get 2 cols each
              col_class = idx < 2 ? "lg:col-span-4 lg:row-span-1" : "lg:col-span-2 lg:row-span-1"
              aspect_class = idx < 2 ? "aspect-[4/3] lg:aspect-auto lg:h-full" : "aspect-[3/4] lg:aspect-auto lg:h-full"
            %>
            <%= link_to category_path(slug: category.slug), class: "group category-card relative overflow-hidden rounded-2xl #{col_class}" do %>
              <div class="<%= aspect_class %> w-full overflow-hidden rounded-2xl" style="background: <%= category_gradients[idx % 6] %>;">
                <img src="<%= category_images[category.name] || fallback_images[idx % fallback_images.length] %>" alt="<%= category.name %>" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-75" loading="lazy">
              </div>
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <!-- Gold border glow on hover -->
              <div class="absolute inset-0 rounded-2xl border-2 border-transparent transition-colors duration-500 group-hover:border-[var(--gold)]/30" style="pointer-events: none;"></div>
              <div class="absolute bottom-0 left-0 right-0 p-5 lg:p-6">
                <h3 class="font-display text-xl font-semibold text-white lg:text-2xl"><%= category.name %></h3>
                <p class="mt-1 text-xs text-white/50"><%= @category_counts[category] || 0 %> products</p>
                <div class="mt-3 flex items-center gap-1.5 text-xs font-medium opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:gap-2.5" style="color: var(--gold);">
                  Shop Now
                  <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <!-- View all link (mobile) -->
        <div class="mt-8 text-center lg:hidden">
          <%= link_to products_path, class: "inline-flex items-center gap-2 text-sm font-medium transition-colors hover:opacity-70", style: "color: var(--black);" do %>
            View All Categories
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- ═══════════════════════════════════════════════════════════════════
       NEW ARRIVALS
       ═══════════════════════════════════════════════════════════════════ -->
  <% if @featured_products.any? %>
    <section style="background: linear-gradient(180deg, var(--cream) 0%, #e6e0d5 50%, var(--cream) 100%);">
      <div class="mx-auto max-w-7xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
        <div class="flex items-end justify-between">
          <div>
            <div class="flex items-center gap-3">
              <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Just Dropped</p>
              <span class="h-px flex-1 max-w-[3rem]" style="background: var(--gold); opacity: 0.4;"></span>
            </div>
            <h2 class="mt-3 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">New <em class="italic">Arrivals</em></h2>
            <p class="mt-2 text-sm" style="color: var(--mid-gray);">Fresh finds across all categories, added daily</p>
          </div>
          <%= link_to products_path(sort: "newest"), class: "hidden items-center gap-2 text-sm font-medium transition-colors sm:flex hover:opacity-70", style: "color: var(--black);" do %>
            View All
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
        </div>
        <div class="mt-12 grid grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3 lg:grid-cols-4 lg:gap-x-8">
          <% @featured_products.first(8).each do |product| %>
            <%= render "storefront/products/product_card", product: product %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- ═══════════════════════════════════════════════════════════════════
       WHY CHOOSE US - Feature highlight strip
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background: var(--black);">
    <div class="absolute inset-0 grain-overlay opacity-20"></div>
    <!-- Decorative gold lines -->
    <div class="absolute top-0 left-0 right-0 gold-line opacity-30"></div>
    <div class="absolute bottom-0 left-0 right-0 gold-line opacity-30"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">Why RailsyCommerce</p>
        <h2 class="mt-3 font-display text-3xl font-light tracking-tight text-white sm:text-4xl">Built <em class="italic" style="color: var(--gold);">Different</em></h2>
      </div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <% [
          { icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z", title: "Lightning Fast", desc: "Blazing fast checkout and delivery. Your time matters — we respect it." },
          { icon: "M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z", title: "Curated Selection", desc: "Every single product is hand-picked and quality-verified by our team." },
          { icon: "M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418", title: "Global Shipping", desc: "We ship to 190+ countries. Same quality, wherever you are in the world." }
        ].each do |feature| %>
          <div class="text-center group">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full transition-all duration-300 group-hover:scale-110" style="background: rgba(201,169,110,0.1); border: 1px solid rgba(201,169,110,0.15);">
              <svg class="h-6 w-6" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="<%= feature[:icon] %>" />
              </svg>
            </div>
            <h3 class="mt-5 font-display text-xl font-semibold text-white"><%= feature[:title] %></h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: rgba(255,255,255,0.4);"><%= feature[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       SPLIT PROMOTIONAL BANNERS
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="mx-auto max-w-7xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
    <!-- Section header -->
    <div class="text-center max-w-xl mx-auto mb-12">
      <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Special Offers</p>
      <h2 class="mt-3 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">Don't <em class="italic">Miss Out</em></h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <!-- Left: New Season -->
      <div class="promo-card group relative overflow-hidden rounded-2xl" style="background: linear-gradient(135deg, rgba(201,169,110,0.08) 0%, rgba(201,169,110,0.15) 40%, rgba(201,169,110,0.05) 100%); min-height: 360px; border: 1px solid rgba(201,169,110,0.12);">
        <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
          <span class="font-display text-[9rem] font-bold uppercase leading-none opacity-[0.03]" style="color: var(--gold);">NEW</span>
        </div>
        <div class="absolute top-0 right-0 w-40 h-40 opacity-15" style="background: radial-gradient(circle at top right, var(--gold) 0%, transparent 70%);"></div>
        <div class="absolute bottom-0 left-0 w-24 h-24 opacity-10" style="background: radial-gradient(circle at bottom left, var(--gold) 0%, transparent 70%);"></div>
        <div class="relative z-10 flex h-full flex-col justify-end p-8 lg:p-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Spring 2026</p>
          <h3 class="mt-3 font-display text-3xl font-light sm:text-4xl" style="color: var(--black);">New <em class="italic">Season</em></h3>
          <p class="mt-3 text-sm leading-relaxed max-w-sm" style="color: var(--mid-gray);">Fresh picks across electronics, fashion, home & more — discover what's new this season</p>
          <%= link_to products_path(sort: "newest"), class: "mt-6 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider transition-colors hover:opacity-70", style: "color: var(--black);" do %>
            Shop New
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
        </div>
      </div>

      <!-- Right: Sale -->
      <div class="promo-card group relative overflow-hidden rounded-2xl grain-overlay" style="background: linear-gradient(135deg, var(--black) 0%, #1a1510 50%, #1f1812 100%); min-height: 360px;">
        <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
          <span class="font-display text-[10rem] font-bold uppercase leading-none opacity-[0.04] text-white">SALE</span>
        </div>
        <div class="absolute bottom-0 left-0 w-56 h-56 opacity-12" style="background: radial-gradient(circle at bottom left, var(--gold) 0%, transparent 65%);"></div>
        <div class="absolute top-0 right-0 w-32 h-32 opacity-8" style="background: radial-gradient(circle at top right, var(--red) 0%, transparent 70%);"></div>
        <div class="relative z-10 flex h-full flex-col justify-end p-8 lg:p-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Limited Time</p>
          <h3 class="mt-3 font-display text-3xl font-light text-white sm:text-4xl">Up to <span style="color: var(--red);" class="font-semibold">50% Off</span></h3>
          <p class="mt-3 text-sm leading-relaxed text-white/45 max-w-sm">Premium products at exceptional prices across all departments</p>
          <%= link_to products_path(on_sale: true), class: "mt-6 inline-flex items-center gap-2 border px-7 py-3 text-sm font-semibold uppercase tracking-wider text-white transition-all duration-300 hover:bg-white/10", style: "border-color: rgba(255,255,255,0.2);" do %>
            Shop Sale
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       ON SALE
       ═══════════════════════════════════════════════════════════════════ -->
  <% sale_products = @sale_products || @featured_products.select { |p| p.master_variant&.on_sale? } %>
  <% if sale_products.any? %>
    <section style="background: linear-gradient(180deg, var(--cream) 0%, #e6e0d5 50%, var(--cream) 100%);">
      <div class="mx-auto max-w-7xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
        <div class="flex items-end justify-between">
          <div class="flex items-center gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--red);">Hot Deals</p>
              <h2 class="mt-2 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">On <em class="italic">Sale</em></h2>
            </div>
            <span class="shimmer-badge ml-2 rounded-full px-4 py-1.5 text-xs font-bold text-white shadow-lg" style="background: linear-gradient(135deg, var(--red) 0%, #e74c3c 100%);">Up to 50% Off</span>
          </div>
          <%= link_to products_path(on_sale: true), class: "hidden items-center gap-2 text-sm font-medium transition-colors sm:flex hover:opacity-70", style: "color: var(--black);" do %>
            View All
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          <% end %>
        </div>
        <div class="mt-12 grid grid-cols-2 gap-x-4 gap-y-10 sm:grid-cols-3 lg:grid-cols-4 lg:gap-x-8">
          <% sale_products.first(4).each do |product| %>
            <%= render "storefront/products/product_card", product: product %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <!-- ═══════════════════════════════════════════════════════════════════
       NEWSLETTER
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, var(--black) 0%, #1a1510 40%, #12100c 100%);">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] opacity-[0.07]" style="background: radial-gradient(circle, var(--gold) 0%, transparent 60%);"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 opacity-[0.05]" style="background: radial-gradient(circle, var(--gold) 0%, transparent 55%);"></div>
    <div class="absolute inset-0 grain-overlay opacity-25"></div>
    <div class="absolute top-0 left-0 right-0 gold-line opacity-25"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
      <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between">
        <!-- Left: Text -->
        <div class="max-w-lg">
          <div class="flex items-center gap-3">
            <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">Newsletter</p>
            <span class="h-px flex-1 max-w-[2rem]" style="background: var(--gold); opacity: 0.3;"></span>
          </div>
          <h2 class="mt-4 font-display text-3xl font-light tracking-tight text-white sm:text-4xl lg:text-5xl">
            Get <em class="italic" style="color: var(--gold);">Exclusive</em><br class="hidden sm:block"> Deals & Early Access
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-white/40">Be the first to know about new products, flash sales, and curated collections across all categories. Join 50,000+ happy subscribers.</p>
        </div>

        <!-- Right: Form -->
        <div class="flex-1 max-w-md">
          <form class="flex flex-col gap-3 sm:flex-row sm:gap-0" action="#" method="post">
            <input type="email" placeholder="Enter your email address" required
              class="flex-1 border px-6 py-4 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-[var(--gold)] transition-colors duration-300 sm:rounded-l-md"
              style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);">
            <button type="submit" class="btn-subscribe px-8 py-4 text-sm font-semibold uppercase tracking-wider sm:rounded-r-md" style="background: var(--gold); color: var(--black);">
              Subscribe
            </button>
          </form>
          <p class="mt-4 text-xs text-white/20">We respect your privacy. Unsubscribe at any time.</p>
          <!-- Social proof -->
          <div class="mt-6 flex items-center gap-3">
            <div class="flex -space-x-2">
              <% 4.times do |i| %>
                <div class="h-7 w-7 rounded-full border-2 flex items-center justify-center text-[9px] font-bold" style="border-color: var(--black); background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%); color: var(--black);">
                  <%= %w[J M K A][i] %>
                </div>
              <% end %>
            </div>
            <p class="text-xs text-white/30">Join <strong class="text-white/50">50,000+</strong> subscribers</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
