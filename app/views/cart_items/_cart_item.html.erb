<div class="flex gap-5 py-6" id="<%= dom_id(cart_item) %>">
  <!-- Product Image -->
  <div class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-xl bg-gray-100 sm:h-28 sm:w-28">
    <% if cart_item.variant.product.images.attached? %>
      <%= image_tag cart_item.variant.product.images.first, class: "h-full w-full object-cover" %>
    <% else %>
      <div class="flex h-full w-full items-center justify-center text-gray-300">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
      </div>
    <% end %>
  </div>

  <!-- Item Details -->
  <div class="flex flex-1 flex-col justify-between">
    <div class="flex justify-between">
      <div>
        <h3 class="text-sm font-medium text-gray-900">
          <%= link_to cart_item.variant.product.name, product_path(cart_item.variant.product),
            class: "hover:text-indigo-600 transition-colors duration-200" %>
        </h3>
        <% if cart_item.variant.option_values.any? %>
          <p class="mt-1 text-xs text-gray-500"><%= cart_item.variant.options_text %></p>
        <% end %>
      </div>
      <span class="text-sm font-semibold text-gray-900"><%= cart_item.subtotal.format %></span>
    </div>

    <div class="mt-3 flex items-center justify-between">
      <!-- Quantity Controls -->
      <div class="flex items-center" data-controller="quantity">
        <%= form_with url: cart_item_path(cart_item), method: :patch, class: "flex items-center rounded-lg border border-gray-300" do |form| %>
          <button type="button" data-action="quantity#decrement"
            class="flex h-8 w-8 items-center justify-center text-gray-400 hover:text-gray-600 transition-colors duration-200 cursor-pointer">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15"/></svg>
          </button>
          <%= form.number_field "cart_item[quantity]", value: cart_item.quantity, min: 1, max: 99,
            data: { quantity_target: "input" },
            class: "h-8 w-10 border-x border-gray-300 text-center text-xs font-medium text-gray-900 focus:outline-none",
            onchange: "this.form.requestSubmit()" %>
          <button type="button" data-action="quantity#increment"
            class="flex h-8 w-8 items-center justify-center text-gray-400 hover:text-gray-600 transition-colors duration-200 cursor-pointer">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          </button>
        <% end %>
      </div>

      <!-- Remove -->
      <%= button_to cart_item_path(cart_item), method: :delete,
        class: "text-xs font-medium text-red-500 hover:text-red-700 transition-colors duration-200 cursor-pointer" do %>
        Remove
      <% end %>
    </div>
  </div>
</div>
