<% content_for(:title, "Checkout - RailsyCommerce") %>

<!-- Step Indicators -->
<nav class="mb-10">
  <ol class="flex items-center justify-center gap-1 sm:gap-4">
    <% %w[address shipping payment].each_with_index do |step_name, index| %>
      <li class="flex items-center gap-1 sm:gap-2">
        <span class="flex h-7 w-7 sm:h-8 sm:w-8 items-center justify-center rounded-full text-xs sm:text-sm font-medium
          <%= if step_name == @step
                'text-white'
              elsif %w[address shipping payment].index(step_name) < %w[address shipping payment].index(@step)
                'text-white'
              else
                'border text-gray-400'
              end %>"
          style="<%= if step_name == @step
                       'background-color: var(--gold);'
                     elsif %w[address shipping payment].index(step_name) < %w[address shipping payment].index(@step)
                       'background-color: var(--gold); opacity: 0.6;'
                     else
                       'border-color: var(--warm-gray);'
                     end %>">
          <%= index + 1 %>
        </span>
        <span class="hidden text-sm font-medium sm:inline <%= step_name == @step ? '' : 'opacity-50' %>" style="color: var(--black);">
          <%= step_name.capitalize %>
        </span>
      </li>
      <% unless step_name == "payment" %>
        <li class="mx-1 sm:mx-2 h-px w-6 sm:w-16" style="background-color: var(--warm-gray);"></li>
      <% end %>
    <% end %>
  </ol>
</nav>

<div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
  <!-- Left: Checkout Steps -->
  <div class="lg:col-span-7">
    <turbo-frame id="checkout_steps">
      <% case @step %>
      <% when "address" %>
        <%= render "checkouts/steps/address", address: @address %>
      <% when "shipping" %>
        <%= render "checkouts/steps/shipping", shipping_methods: @shipping_methods %>
      <% when "payment" %>
        <%= render "checkouts/steps/payment", shipping_method: ShippingMethod.find_by(id: session[:checkout_shipping_method_id]) %>
      <% end %>
    </turbo-frame>
  </div>

  <!-- Right: Order Summary -->
  <div class="lg:col-span-5">
    <div class="rounded-xl p-6 lg:sticky lg:top-8" style="background-color: var(--white); border: 1px solid var(--warm-gray);">
      <h2 class="font-display text-xl font-semibold mb-6" style="color: var(--black);">Order Summary</h2>

      <div class="space-y-4 mb-6" style="border-bottom: 1px solid var(--warm-gray); padding-bottom: 1.5rem;">
        <% current_cart.cart_items.includes(variant: { product: { images_attachments: :blob } }).each do |item| %>
          <div class="flex gap-4">
            <div class="h-16 w-16 flex-shrink-0 rounded-lg overflow-hidden" style="background-color: var(--cream);">
              <% if item.variant.product.images.attached? %>
                <%= image_tag item.variant.product.images.first, class: "h-full w-full object-cover" %>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate" style="color: var(--black);"><%= item.variant.product.name %></p>
              <% if item.variant.options_text.present? %>
                <p class="text-xs mt-0.5" style="color: var(--medium-gray);"><%= item.variant.options_text %></p>
              <% end %>
              <p class="text-xs mt-0.5" style="color: var(--medium-gray);">Qty: <%= item.quantity %></p>
            </div>
            <p class="text-sm font-medium" style="color: var(--black);"><%= item.subtotal.format %></p>
          </div>
        <% end %>
      </div>

      <div class="space-y-3 text-sm">
        <div class="flex justify-between">
          <span style="color: var(--medium-gray);">Subtotal</span>
          <span class="font-medium" style="color: var(--black);"><%= current_cart.subtotal.format %></span>
        </div>
        <div class="flex justify-between">
          <span style="color: var(--medium-gray);">Shipping</span>
          <span class="font-medium" style="color: var(--black);">
            <% if session[:checkout_shipping_method_id] %>
              <%= ShippingMethod.find(session[:checkout_shipping_method_id]).price.format %>
            <% else %>
              Calculated next
            <% end %>
          </span>
        </div>
        <div class="flex justify-between">
          <span style="color: var(--medium-gray);">Tax</span>
          <span class="font-medium" style="color: var(--black);">Calculated at checkout</span>
        </div>
      </div>

      <div class="mt-4 pt-4 flex justify-between" style="border-top: 1px solid var(--warm-gray);">
        <span class="font-display text-lg font-semibold" style="color: var(--black);">Total</span>
        <span class="font-display text-lg font-semibold" style="color: var(--black);"><%= current_cart.subtotal.format %></span>
      </div>
    </div>
  </div>
</div>
