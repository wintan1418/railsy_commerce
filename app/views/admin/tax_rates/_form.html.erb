<%= form_with model: [:admin, tax_rate], class: "space-y-6" do |form| %>
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6 space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, required: true, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400" %>
      </div>
      <div>
        <%= form.label :rate, "Rate (decimal, e.g. 0.08 for 8%)", class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :rate, step: 0.000001, min: 0, max: 1, required: true, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400" %>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :country_code, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :country_code, required: true, maxlength: 2, placeholder: "US", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400" %>
      </div>
      <div>
        <%= form.label :state, "State (optional)", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :state, placeholder: "NY", class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400" %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= form.check_box :active, class: "h-4 w-4 rounded border-gray-300" %>
      <%= form.label :active, "Active", class: "text-sm font-medium text-gray-700" %>
    </div>
  </div>
  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", admin_tax_rates_path, class: "rounded-lg bg-white border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700" %>
    <%= form.submit tax_rate.persisted? ? "Update" : "Create Tax Rate", class: "rounded-lg px-4 py-2 text-sm font-semibold text-white cursor-pointer", style: "background: var(--gold);" %>
  </div>
<% end %>
