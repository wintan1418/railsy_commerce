<%= form_with model: [:admin, product], class: "space-y-6" do |form| %>
  <% if product.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6 space-y-4">
    <h2 class="text-lg font-semibold text-gray-900">Product Details</h2>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, required: true,
        class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 4,
        class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :status, Product.statuses.keys.map { |s| [s.capitalize, s] },
          {}, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :category_id, Category.ordered.pluck(:name, :id),
          { include_blank: "No category" },
          class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= form.label :images, class: "block text-sm font-medium text-gray-700" %>
      <%= form.file_field :images, multiple: true, accept: "image/*",
        class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6 space-y-4">
    <h2 class="text-lg font-semibold text-gray-900">SEO</h2>

    <div>
      <%= form.label :meta_title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :meta_title,
        class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :meta_description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :meta_description, rows: 2,
        class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", admin_products_path, class: "rounded-lg bg-white border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <%= form.submit product.persisted? ? "Update Product" : "Create Product",
      class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer" %>
  </div>
<% end %>
