<h1 class="text-2xl font-bold text-gray-900">Store Settings</h1>

<%= form_with url: admin_settings_path, method: :patch, class: "mt-8 space-y-6" do |form| %>
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6 space-y-5">
    <h2 class="text-lg font-semibold text-gray-900">General</h2>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700">Store Name</label>
        <input type="text" name="settings[store_name]" value="<%= @settings[:store_name] %>"
          class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1" style="focus:ring-color: var(--gold);">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Contact Email</label>
        <input type="email" name="settings[store_email]" value="<%= @settings[:store_email] %>"
          class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Currency</label>
        <select name="settings[store_currency]" class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm">
          <% %w[USD EUR GBP CAD AUD NGN].each do |c| %>
            <option value="<%= c %>" <%= 'selected' if @settings[:store_currency] == c %>><%= c %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Free Shipping Threshold (cents)</label>
        <input type="number" name="settings[free_shipping_threshold]" value="<%= @settings[:free_shipping_threshold] %>"
          class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
        <p class="mt-1 text-xs text-gray-400">e.g., 7500 = $75.00</p>
      </div>
    </div>
  </div>

  <div class="flex justify-end">
    <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer" style="background: var(--gold);">
      Save Settings
    </button>
  </div>
<% end %>
