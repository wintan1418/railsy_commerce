<div style="background: var(--warm-white);">
  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="background: var(--black);">
    <div class="absolute inset-0 grain-overlay opacity-20"></div>
    <div class="absolute top-0 left-0 right-0 gold-line opacity-30"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] opacity-[0.06]" style="background: radial-gradient(circle, var(--gold) 0%, transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 py-24 sm:px-8 lg:px-12 lg:py-32">
      <div class="max-w-2xl">
        <div class="flex items-center gap-4">
          <span class="block h-px w-12" style="background: var(--gold);"></span>
          <span class="text-xs font-medium uppercase tracking-[0.35em]" style="color: var(--gold);">Professional Services</span>
        </div>
        <h1 class="mt-6 font-display text-4xl font-light tracking-tight text-white sm:text-5xl lg:text-6xl">
          Need Help<br>Setting <em class="italic shimmer-gold">Up?</em>
        </h1>
        <p class="mt-6 text-base leading-relaxed" style="color: rgba(255,255,255,0.5);">
          Whether you need a complete store setup, custom features, or ongoing support, our team of experienced developers is here to bring your vision to life.
        </p>
        <div class="mt-8">
          <a href="#services" class="inline-flex items-center gap-3 px-10 py-4 text-sm font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:opacity-90" style="background: var(--gold); color: var(--black);">
            View Services
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" /></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 gold-line opacity-30"></div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-20 lg:py-28" style="background: var(--warm-white);">
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">What We Offer</p>
        <h2 class="mt-3 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">Our <em class="italic">Services</em></h2>
        <p class="mt-4 text-sm leading-relaxed" style="color: var(--mid-gray);">From initial setup to ongoing maintenance, we offer comprehensive e-commerce solutions.</p>
        <div class="gold-line mt-6 mx-auto w-20 opacity-40"></div>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% [
          { title: "Store Setup & Configuration", price: "$299", period: "one-time", description: "Complete store configuration including products, categories, payment integration, shipping methods, and email setup. We'll get your store ready to accept orders.", icon: "M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0021 9.349m-18 0a2.999 2.999 0 00.75-1.974V5.25A2.25 2.25 0 016 3h12a2.25 2.25 0 012.25 2.25v2.125a3 3 0 01-.75 1.974" },
          { title: "Custom Feature Development", price: "$149", period: "/hour", description: "Need something specific? Custom payment gateways, third-party integrations, unique checkout flows, loyalty programs, subscription systems, and more.", icon: "M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" },
          { title: "Theme Customization", price: "$199", period: "one-time", description: "Custom color schemes, typography, layout changes, and brand-specific design updates to make your store uniquely yours.", icon: "M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" },
          { title: "Deployment & DevOps", price: "$399", period: "one-time", description: "Production deployment to your preferred hosting platform (Kamal, Railway, Render, DigitalOcean, or Heroku). Includes SSL, database setup, and monitoring.", icon: "M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" },
          { title: "Ongoing Maintenance", price: "$99", period: "/month", description: "Monthly maintenance plan including security updates, bug fixes, performance monitoring, backups, and up to 2 hours of minor changes per month.", icon: "M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l5.653-4.655m0 0a3.75 3.75 0 00-1.453-.853l-3.15-1.057a2.25 2.25 0 01-1.442-1.442l-1.057-3.15a.75.75 0 01.242-.826l1.862-1.396a.75.75 0 011.065.114l.974 1.195a2.25 2.25 0 001.654.88l3.274.138a.75.75 0 01.597.35l.974 1.623a.75.75 0 01-.136.98L15.17 11.42z" },
          { title: "Training & Consultation", price: "$89", period: "/hour", description: "One-on-one sessions to teach you how to manage your store, add products, process orders, run promotions, and make the most of every feature.", icon: "M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" }
        ].each do |service| %>
          <div class="group relative overflow-hidden rounded-2xl bg-white p-8 ring-1 ring-gray-900/5 transition-all duration-300 hover:shadow-lg hover:ring-gray-900/10">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl" style="background: rgba(201,169,110,0.1);">
              <svg class="h-6 w-6" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="<%= service[:icon] %>" />
              </svg>
            </div>
            <h3 class="mt-5 font-display text-xl font-semibold" style="color: var(--black);"><%= service[:title] %></h3>
            <div class="mt-2 flex items-baseline gap-1">
              <span class="text-2xl font-bold" style="color: var(--gold);"><%= service[:price] %></span>
              <span class="text-sm" style="color: var(--mid-gray);"><%= service[:period] %></span>
            </div>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--mid-gray);"><%= service[:description] %></p>
            <a href="#contact" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:opacity-70" style="color: var(--gold);">
              Get Started
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- About the Developer -->
  <section class="relative overflow-hidden" style="background: var(--black);">
    <div class="absolute inset-0 grain-overlay opacity-20"></div>
    <div class="absolute top-0 left-0 right-0 gold-line opacity-25"></div>
    <div class="absolute bottom-0 left-0 right-0 gold-line opacity-25"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
      <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:gap-16">
        <div class="flex-1">
          <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">About</p>
          <h2 class="mt-3 font-display text-3xl font-light tracking-tight text-white sm:text-4xl">Meet Your <em class="italic" style="color: var(--gold);">Developer</em></h2>
          <p class="mt-6 text-sm leading-relaxed" style="color: rgba(255,255,255,0.5);">
            With years of experience building e-commerce solutions on Ruby on Rails, I specialize in creating fast, reliable, and beautiful online stores. I've helped dozens of businesses launch and scale their online presence.
          </p>
          <p class="mt-4 text-sm leading-relaxed" style="color: rgba(255,255,255,0.5);">
            Every project gets my full attention. I believe in clean code, thorough testing, and delivering on time. Your success is my success.
          </p>
          <div class="mt-8 grid grid-cols-3 gap-6">
            <div>
              <p class="font-display text-2xl font-semibold" style="color: var(--gold);">50+</p>
              <p class="text-[11px] uppercase tracking-wider" style="color: rgba(255,255,255,0.3);">Projects</p>
            </div>
            <div>
              <p class="font-display text-2xl font-semibold" style="color: var(--gold);">8+</p>
              <p class="text-[11px] uppercase tracking-wider" style="color: rgba(255,255,255,0.3);">Years Exp.</p>
            </div>
            <div>
              <p class="font-display text-2xl font-semibold" style="color: var(--gold);">100%</p>
              <p class="text-[11px] uppercase tracking-wider" style="color: rgba(255,255,255,0.3);">Satisfaction</p>
            </div>
          </div>
        </div>
        <div class="flex-shrink-0">
          <div class="h-64 w-64 rounded-2xl" style="background: linear-gradient(135deg, rgba(201,169,110,0.15) 0%, rgba(201,169,110,0.05) 100%); border: 1px solid rgba(201,169,110,0.2);">
            <div class="flex h-full w-full items-center justify-center">
              <div class="text-center">
                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full" style="background: rgba(201,169,110,0.15);">
                  <svg class="h-10 w-10" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                  </svg>
                </div>
                <p class="mt-3 text-xs" style="color: rgba(255,255,255,0.3);">Add your photo here</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Placeholder -->
  <section class="py-20 lg:py-28" style="background: linear-gradient(180deg, var(--cream) 0%, var(--warm-white) 100%);">
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">Testimonials</p>
        <h2 class="mt-3 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">What Clients <em class="italic">Say</em></h2>
        <div class="gold-line mt-6 mx-auto w-20 opacity-40"></div>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <% [
          { name: "Sarah M.", role: "Boutique Owner", quote: "The setup was incredibly smooth. My store was live and taking orders within 48 hours. The attention to detail is remarkable." },
          { name: "James K.", role: "E-commerce Founder", quote: "Custom features were delivered exactly as specified and on time. The code quality is excellent and easy to maintain." },
          { name: "Maria L.", role: "Small Business Owner", quote: "The ongoing maintenance plan gives me peace of mind. I can focus on my business while knowing my store is in good hands." }
        ].each do |testimonial| %>
          <div class="rounded-2xl bg-white p-8 ring-1 ring-gray-900/5">
            <div class="flex gap-1">
              <% 5.times do %>
                <svg class="h-4 w-4" style="color: var(--gold);" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
                </svg>
              <% end %>
            </div>
            <p class="mt-4 text-sm leading-relaxed" style="color: var(--mid-gray);"><%= testimonial[:quote] %></p>
            <div class="mt-6 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold" style="background: rgba(201,169,110,0.15); color: var(--gold);">
                <%= testimonial[:name][0] %>
              </div>
              <div>
                <p class="text-sm font-semibold" style="color: var(--black);"><%= testimonial[:name] %></p>
                <p class="text-xs" style="color: var(--mid-gray);"><%= testimonial[:role] %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 lg:py-28" style="background: var(--warm-white);">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-12">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">FAQ</p>
        <h2 class="mt-3 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">Common <em class="italic">Questions</em></h2>
      </div>

      <div class="space-y-4">
        <% [
          { q: "How long does a typical store setup take?", a: "A standard store setup takes 2-3 business days. This includes product configuration, payment integration, shipping setup, and basic customization. More complex setups with custom features may take 1-2 weeks." },
          { q: "What's included in the setup fee?", a: "The setup fee covers complete store configuration: adding your products and categories, setting up Stripe or other payment gateways, configuring shipping methods and tax rates, email notification setup, and basic theme customization to match your brand." },
          { q: "Do you offer refunds?", a: "Yes, if we haven't started working on your project, you can get a full refund. Once work has begun, we'll charge only for the time spent. We believe in fair, transparent pricing." },
          { q: "Can you work with my existing design?", a: "Absolutely! We can customize the theme to match your brand guidelines, including colors, fonts, layout changes, and custom components. Just send us your design files or brand guide." },
          { q: "What about hosting?", a: "We can deploy your store to any major hosting platform: Railway, Render, DigitalOcean, Heroku, or your own server with Kamal. Hosting costs are separate and depend on the platform you choose (typically $7-25/month)." },
          { q: "Do you provide ongoing support?", a: "Yes! Our monthly maintenance plan ($99/mo) includes security updates, bug fixes, performance monitoring, and up to 2 hours of minor changes. For larger changes, we bill at our hourly rate." }
        ].each do |faq| %>
          <div class="rounded-xl bg-white p-6 ring-1 ring-gray-900/5">
            <h3 class="text-sm font-semibold" style="color: var(--black);"><%= faq[:q] %></h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--mid-gray);"><%= faq[:a] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="relative overflow-hidden" style="background: var(--black);">
    <div class="absolute inset-0 grain-overlay opacity-20"></div>
    <div class="absolute top-0 left-0 right-0 gold-line opacity-25"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] opacity-[0.06]" style="background: radial-gradient(circle, var(--gold) 0%, transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">Get in Touch</p>
        <h2 class="mt-3 font-display text-3xl font-light tracking-tight text-white sm:text-4xl">Start Your <em class="italic" style="color: var(--gold);">Project</em></h2>
        <p class="mt-4 text-sm leading-relaxed" style="color: rgba(255,255,255,0.4);">Tell us about your project and we'll get back to you within 24 hours.</p>
      </div>

      <form action="mailto:hello@railsycommerce.com" method="post" enctype="text/plain" class="space-y-5">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium" style="color: rgba(255,255,255,0.6);">Your Name</label>
            <input type="text" name="name" required placeholder="John Doe"
              class="mt-1.5 block w-full rounded-lg border px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-[var(--gold)] transition-colors"
              style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);">
          </div>
          <div>
            <label class="block text-sm font-medium" style="color: rgba(255,255,255,0.6);">Your Email</label>
            <input type="email" name="email" required placeholder="john@example.com"
              class="mt-1.5 block w-full rounded-lg border px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-[var(--gold)] transition-colors"
              style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium" style="color: rgba(255,255,255,0.6);">Service Interested In</label>
          <select name="service" class="mt-1.5 block w-full rounded-lg border px-4 py-3 text-sm text-white focus:outline-none focus:border-[var(--gold)] transition-colors"
            style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);">
            <option value="" style="background: #1a1a1a;">Select a service...</option>
            <option value="setup" style="background: #1a1a1a;">Store Setup & Configuration ($299)</option>
            <option value="custom" style="background: #1a1a1a;">Custom Feature Development ($149/hr)</option>
            <option value="theme" style="background: #1a1a1a;">Theme Customization ($199)</option>
            <option value="deploy" style="background: #1a1a1a;">Deployment & DevOps ($399)</option>
            <option value="maintenance" style="background: #1a1a1a;">Ongoing Maintenance ($99/mo)</option>
            <option value="training" style="background: #1a1a1a;">Training & Consultation ($89/hr)</option>
            <option value="other" style="background: #1a1a1a;">Other / Not Sure</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium" style="color: rgba(255,255,255,0.6);">Tell Us About Your Project</label>
          <textarea name="message" rows="5" required placeholder="Describe what you need help with..."
            class="mt-1.5 block w-full rounded-lg border px-4 py-3 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-[var(--gold)] transition-colors resize-none"
            style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1);"></textarea>
        </div>

        <div class="text-center pt-2">
          <button type="submit" class="inline-flex items-center gap-3 px-10 py-4 text-sm font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:opacity-90 cursor-pointer" style="background: var(--gold); color: var(--black);">
            Send Message
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
          </button>
        </div>
      </form>
    </div>
  </section>
</div>
