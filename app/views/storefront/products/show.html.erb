<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Breadcrumb -->
  <nav class="flex text-sm text-gray-500 mb-6">
    <%= link_to "Home", root_path, class: "hover:text-gray-900" %>
    <span class="mx-2">/</span>
    <%= link_to "Products", products_path, class: "hover:text-gray-900" %>
    <% if @product.category %>
      <span class="mx-2">/</span>
      <%= link_to @product.category.name, category_path(slug: @product.category.slug), class: "hover:text-gray-900" %>
    <% end %>
    <span class="mx-2">/</span>
    <span class="text-gray-900"><%= @product.name %></span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Product Images -->
    <div>
      <div class="aspect-square overflow-hidden rounded-xl bg-gray-100">
        <% if @product.images.attached? %>
          <%= image_tag @product.images.first, class: "h-full w-full object-cover" %>
        <% else %>
          <div class="h-full w-full flex items-center justify-center text-gray-400">
            <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
            </svg>
          </div>
        <% end %>
      </div>
      <% if @product.images.attached? && @product.images.count > 1 %>
        <div class="mt-4 grid grid-cols-4 gap-4">
          <% @product.images.each do |image| %>
            <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
              <%= image_tag image, class: "h-full w-full object-cover" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Product Info -->
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @product.name %></h1>

      <div class="mt-4 flex items-center gap-3">
        <% if @master_variant&.on_sale? %>
          <span class="text-2xl font-bold text-red-600"><%= @master_variant.price.format %></span>
          <span class="text-lg text-gray-400 line-through"><%= @master_variant.compare_at_price.format %></span>
          <span class="rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">
            Sale
          </span>
        <% elsif @master_variant %>
          <span class="text-2xl font-bold text-gray-900"><%= @master_variant.price.format %></span>
        <% end %>
      </div>

      <% if @product.description.present? %>
        <div class="mt-6 text-gray-600 leading-relaxed">
          <%= simple_format @product.description %>
        </div>
      <% end %>

      <!-- Variant Selection -->
      <% non_master_variants = @variants.reject(&:is_master?) %>
      <% if non_master_variants.any? %>
        <div class="mt-6 space-y-4">
          <% @product.option_types.each do |option_type| %>
            <div>
              <h3 class="text-sm font-medium text-gray-900"><%= option_type.presentation %></h3>
              <div class="mt-2 flex flex-wrap gap-2">
                <% option_type.option_values.each do |ov| %>
                  <span class="px-3 py-1.5 text-sm rounded-full border border-gray-300 text-gray-700 hover:border-indigo-500 cursor-pointer">
                    <%= ov.presentation %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Add to Cart -->
      <% if @product.in_stock? && @master_variant %>
        <div class="mt-8">
          <%= form_with url: cart_items_path, method: :post, class: "flex items-center gap-4" do |form| %>
            <%= form.hidden_field :variant_id, value: @master_variant.id %>
            <%= form.number_field :quantity, value: 1, min: 1, max: 99,
              class: "w-20 rounded-lg border border-gray-300 px-3 py-2.5 text-center text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
            <%= form.submit "Add to Cart",
              class: "flex-1 rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
          <% end %>
        </div>
      <% else %>
        <div class="mt-8">
          <button disabled class="w-full rounded-lg bg-gray-300 px-6 py-3 text-sm font-semibold text-gray-500 cursor-not-allowed">
            Out of Stock
          </button>
        </div>
      <% end %>

      <!-- Stock indicator -->
      <% if @master_variant %>
        <div class="mt-4">
          <% if @master_variant.in_stock? %>
            <span class="text-sm text-green-600">In Stock</span>
          <% else %>
            <span class="text-sm text-red-600">Out of Stock</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
