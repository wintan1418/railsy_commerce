<div class="flex items-center justify-between">
  <h1 class="text-2xl font-bold text-gray-900">Shipping Methods</h1>
  <%= link_to "New Shipping Method", new_admin_shipping_method_path, class: "rounded-lg px-4 py-2.5 text-sm font-semibold text-white", style: "background: var(--gold);" %>
</div>

<div class="mt-6 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-100">
      <thead>
        <tr class="bg-gray-50/50">
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Name</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Price</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Delivery Estimate</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Status</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @shipping_methods.each do |method| %>
          <tr class="hover:bg-gray-50/50 transition-colors duration-150">
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-gray-900"><%= method.name %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900"><%= method.price.format %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500"><%= method.delivery_estimate || "—" %></td>
            <td class="whitespace-nowrap px-6 py-4">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold <%= method.active? ? 'bg-green-50 text-green-700 ring-1 ring-green-600/20' : 'bg-gray-100 text-gray-500 ring-1 ring-gray-300/20' %>">
                <%= method.active? ? "Active" : "Inactive" %>
              </span>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm space-x-2">
              <%= link_to "Edit", edit_admin_shipping_method_path(method), class: "font-medium", style: "color: var(--gold);" %>
              <%= button_to "Delete", admin_shipping_method_path(method), method: :delete, data: { turbo_confirm: "Delete this shipping method?" }, class: "text-red-500 font-medium cursor-pointer" %>
            </td>
          </tr>
        <% end %>
        <% if @shipping_methods.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-sm text-gray-400">No shipping methods yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
