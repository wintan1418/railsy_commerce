<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm mb-8" style="color: var(--mid-gray);">
    <%= link_to "Home", root_path, class: "transition-colors duration-200 hover:text-[var(--gold)]" %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <span class="font-medium" style="color: var(--black);">Compare Products</span>
  </nav>

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Side by Side</p>
      <h1 class="mt-2 font-display text-3xl font-light tracking-tight" style="color: var(--black);">Compare <em class="italic">Products</em></h1>
    </div>
    <%= link_to "Back to Shop", products_path, class: "text-sm font-medium transition-colors hover:opacity-70", style: "color: var(--gold);" %>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full min-w-[640px]">
      <!-- Product Images -->
      <tr>
        <td class="w-40 py-4 pr-4 align-top">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Product</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 align-top text-center" style="min-width: 200px;">
            <div class="mx-auto aspect-square w-full max-w-[200px] overflow-hidden rounded-xl" style="background: var(--cream);">
              <% if product.images.attached? %>
                <%= image_tag product.images.first, class: "h-full w-full object-cover" %>
              <% else %>
                <div class="flex h-full w-full items-center justify-center" style="color: var(--light-gray);">
                  <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                  </svg>
                </div>
              <% end %>
            </div>
            <h3 class="mt-3 font-display text-base font-semibold" style="color: var(--black);">
              <%= link_to product.name, product_path(product), class: "transition-colors hover:text-[var(--gold)]" %>
            </h3>
          </td>
        <% end %>
      </tr>

      <!-- Price -->
      <tr class="border-t" style="border-color: var(--cream);">
        <td class="py-4 pr-4">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Price</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 text-center">
            <% variant = product.master_variant %>
            <% if variant&.on_sale? %>
              <span class="font-display text-lg font-semibold" style="color: var(--red);"><%= variant.price.format %></span>
              <span class="ml-1 text-sm line-through" style="color: var(--mid-gray);"><%= variant.compare_at_price.format %></span>
            <% elsif variant %>
              <span class="font-display text-lg font-semibold" style="color: var(--black);"><%= variant.price.format %></span>
            <% end %>
          </td>
        <% end %>
      </tr>

      <!-- Category -->
      <tr class="border-t" style="border-color: var(--cream);">
        <td class="py-4 pr-4">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Category</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 text-center text-sm" style="color: var(--text-body);">
            <%= product.category&.name || "Uncategorized" %>
          </td>
        <% end %>
      </tr>

      <!-- Rating -->
      <tr class="border-t" style="border-color: var(--cream);">
        <td class="py-4 pr-4">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Rating</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 text-center">
            <% avg = product.average_rating || 0 %>
            <div class="flex items-center justify-center gap-1">
              <div class="flex" style="color: var(--gold);">
                <% 5.times do |i| %>
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" <%= "style=\"color: var(--light-gray);\"".html_safe if i >= avg %>>
                    <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/>
                  </svg>
                <% end %>
              </div>
              <span class="text-xs" style="color: var(--mid-gray);">(<%= product.reviews_count %>)</span>
            </div>
          </td>
        <% end %>
      </tr>

      <!-- Stock Status -->
      <tr class="border-t" style="border-color: var(--cream);">
        <td class="py-4 pr-4">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Availability</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 text-center">
            <% if product.in_stock? %>
              <span class="inline-flex items-center gap-1 text-sm text-green-600">
                <span class="h-2 w-2 rounded-full bg-green-500"></span>
                In Stock
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 text-sm" style="color: var(--red);">
                <span class="h-2 w-2 rounded-full" style="background: var(--red);"></span>
                Out of Stock
              </span>
            <% end %>
          </td>
        <% end %>
      </tr>

      <!-- Description -->
      <tr class="border-t" style="border-color: var(--cream);">
        <td class="py-4 pr-4 align-top">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Description</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 align-top">
            <p class="text-sm leading-relaxed line-clamp-4" style="color: var(--text-body);"><%= product.description %></p>
          </td>
        <% end %>
      </tr>

      <!-- Add to Cart -->
      <tr class="border-t" style="border-color: var(--cream);">
        <td class="py-4 pr-4">
          <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Action</span>
        </td>
        <% @products.each do |product| %>
          <td class="p-4 text-center">
            <% variant = product.master_variant %>
            <% if variant && product.in_stock? %>
              <%= form_with url: cart_items_path, method: :post do |form| %>
                <%= form.hidden_field :variant_id, value: variant.id %>
                <%= form.hidden_field :quantity, value: 1 %>
                <%= form.submit "Add to Cart",
                  class: "w-full rounded-lg py-2.5 text-xs font-semibold uppercase tracking-wider text-white transition-all duration-200 cursor-pointer",
                  style: "background: var(--black);",
                  onmouseover: "this.style.background='var(--gold)'; this.style.color='var(--black)';",
                  onmouseout: "this.style.background='var(--black)'; this.style.color='white';" %>
              <% end %>
            <% else %>
              <button disabled class="w-full rounded-lg py-2.5 text-xs font-semibold cursor-not-allowed" style="background: var(--cream); color: var(--mid-gray);">
                Out of Stock
              </button>
            <% end %>
          </td>
        <% end %>
      </tr>
    </table>
  </div>
</div>
