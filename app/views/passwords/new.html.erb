<div class="flex min-h-[80vh] items-center justify-center px-4 py-12 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <div class="rounded-2xl bg-white p-8 shadow-xl ring-1 ring-gray-900/5 sm:p-10">
      <!-- Header -->
      <div class="text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-amber-100">
          <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
          </svg>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-gray-900">Forgot your password?</h1>
        <p class="mt-2 text-sm text-gray-500">No worries, we'll send you reset instructions.</p>
      </div>

      <% if flash[:alert] %>
        <div class="mt-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm text-red-800"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <%= form_with url: passwords_path, class: "mt-8 space-y-5" do |form| %>
        <div>
          <%= form.label :email_address, "Email address", class: "block text-sm font-medium text-gray-700" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            value: params[:email_address],
            class: "mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600/20 transition-all duration-200",
            placeholder: "you@example.com" %>
        </div>

        <%= form.submit "Send reset instructions",
          class: "w-full rounded-lg bg-indigo-600 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200 cursor-pointer" %>
      <% end %>

      <p class="mt-6 text-center">
        <%= link_to new_session_path, class: "inline-flex items-center gap-1 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors duration-200" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
          Back to sign in
        <% end %>
      </p>
    </div>
  </div>
</div>
