<div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="text-center mb-10">
    <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Order Tracking</p>
    <h1 class="mt-2 font-display text-3xl font-light tracking-tight" style="color: var(--black);">Order <em class="italic"><%= @order.number %></em></h1>
  </div>

  <!-- Status Progress Bar -->
  <% statuses = %w[order_placed confirmed processing in_transit out_for_delivery delivered] %>
  <% current_idx = statuses.index(@current_status) || 0 %>
  <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 mb-8">
    <div class="flex items-center justify-between mb-4">
      <% statuses.each_with_index do |s, idx| %>
        <div class="flex flex-col items-center flex-1">
          <div class="flex h-8 w-8 items-center justify-center rounded-full text-xs font-bold
            <%= idx <= current_idx ? 'text-white' : '' %>"
            style="<%= idx <= current_idx ? 'background: var(--gold);' : 'background: var(--cream); color: var(--mid-gray);' %>">
            <% if idx < current_idx %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <% else %>
              <%= idx + 1 %>
            <% end %>
          </div>
          <p class="mt-2 text-[10px] font-medium text-center leading-tight hidden sm:block
            <%= idx <= current_idx ? '' : '' %>"
            style="color: <%= idx <= current_idx ? 'var(--gold)' : 'var(--mid-gray)' %>;">
            <%= TrackingUpdate::FRIENDLY_NAMES[s] || s.humanize %>
          </p>
        </div>
        <% unless idx == statuses.size - 1 %>
          <div class="flex-1 h-1 rounded mx-1 mb-6" style="background: <%= idx < current_idx ? 'var(--gold)' : 'var(--cream)' %>;"></div>
        <% end %>
      <% end %>
    </div>

    <% if @order.tracking_number.present? %>
      <div class="mt-4 pt-4 border-t text-center" style="border-color: var(--cream);">
        <p class="text-xs uppercase tracking-wider" style="color: var(--mid-gray);">Tracking Number</p>
        <p class="mt-1 text-sm font-semibold" style="color: var(--black);"><%= @order.tracking_number %></p>
      </div>
    <% end %>

    <% last_update = @tracking_updates.last %>
    <% if last_update&.estimated_delivery %>
      <div class="mt-4 pt-4 border-t text-center" style="border-color: var(--cream);">
        <p class="text-xs uppercase tracking-wider" style="color: var(--mid-gray);">Estimated Delivery</p>
        <p class="mt-1 text-sm font-semibold" style="color: var(--gold);"><%= last_update.estimated_delivery.strftime("%A, %B %d, %Y") %></p>
      </div>
    <% end %>
  </div>

  <!-- Rider Info -->
  <% if @order.delivery&.rider %>
    <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5 mb-8">
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-full text-sm font-bold" style="background: var(--gold); color: var(--black);">
          <%= @order.delivery.rider.first_name&.first %><%= @order.delivery.rider.last_name&.first %>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold" style="color: var(--black);">Your Rider</p>
          <p class="text-xs" style="color: var(--mid-gray);"><%= @order.delivery.rider.full_name %></p>
        </div>
        <% if @order.delivery.rider_phone.present? %>
          <a href="tel:<%= @order.delivery.rider_phone %>" class="flex h-10 w-10 items-center justify-center rounded-full min-h-[44px]" style="background: var(--cream);">
            <svg class="h-5 w-5" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </a>
        <% end %>
      </div>
      <% if @order.delivery.current_location.present? %>
        <div class="mt-3 flex items-center gap-2 text-xs" style="color: var(--mid-gray);">
          <svg class="h-3.5 w-3.5" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          Last seen: <%= @order.delivery.current_location %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Timeline -->
  <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 mb-8">
    <h2 class="text-base font-semibold mb-6" style="color: var(--black);">Delivery Updates</h2>
    <% if @tracking_updates.any? %>
      <div class="relative pl-8">
        <div class="absolute left-3 top-2 bottom-2 w-0.5" style="background: var(--cream);"></div>
        <% @tracking_updates.reverse.each_with_index do |update, idx| %>
          <div class="relative pb-6 last:pb-0">
            <div class="absolute -left-5 top-1 flex h-4 w-4 items-center justify-center rounded-full"
              style="background: <%= idx == 0 ? 'var(--gold)' : 'var(--cream)' %>;">
              <div class="h-2 w-2 rounded-full" style="background: <%= idx == 0 ? 'white' : 'var(--mid-gray)' %>;"></div>
            </div>
            <div>
              <div class="flex items-center gap-3">
                <p class="text-sm font-semibold" style="color: var(--black);"><%= update.friendly_status %></p>
                <span class="text-xs" style="color: var(--mid-gray);"><%= update.created_at.strftime("%b %d at %I:%M %p") %></span>
              </div>
              <p class="mt-1 text-sm" style="color: var(--text-body);"><%= update.description %></p>
              <% if update.location.present? %>
                <p class="mt-0.5 flex items-center gap-1 text-xs" style="color: var(--mid-gray);">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                  <%= update.location %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-sm" style="color: var(--mid-gray);">Your order has been placed and is being processed.</p>
        <p class="mt-1 text-xs" style="color: var(--mid-gray);">Check back later for delivery updates.</p>
      </div>
    <% end %>
  </div>

  <!-- Order Summary -->
  <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
    <h2 class="text-base font-semibold mb-4" style="color: var(--black);">Order Summary</h2>
    <div class="space-y-3">
      <div class="flex justify-between text-sm">
        <span style="color: var(--mid-gray);">Order Number</span>
        <span class="font-medium" style="color: var(--black);"><%= @order.number %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span style="color: var(--mid-gray);">Order Date</span>
        <span style="color: var(--black);"><%= @order.created_at.strftime("%B %d, %Y") %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span style="color: var(--mid-gray);">Status</span>
        <span class="font-medium capitalize" style="color: var(--gold);"><%= @order.status %></span>
      </div>
      <div class="flex justify-between text-sm border-t pt-3" style="border-color: var(--cream);">
        <span class="font-semibold" style="color: var(--black);">Total</span>
        <span class="font-semibold" style="color: var(--black);"><%= @order.total.format %></span>
      </div>
    </div>
  </div>

  <div class="mt-6 text-center">
    <%= link_to "Track Another Order", track_search_path, class: "text-sm font-medium", style: "color: var(--gold);" %>
  </div>
</div>
