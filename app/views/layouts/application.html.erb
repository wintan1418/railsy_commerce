<!DOCTYPE html>
<html class="h-full scroll-smooth">
  <head>
    <title><%= content_for(:title) || "RailsyCommerce" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full antialiased">
    <!-- Announcement Bar -->
    <div style="background: var(--black);">
      <div class="mx-auto max-w-7xl px-4 py-2.5 sm:px-6 lg:px-8">
        <p class="text-center text-xs font-light tracking-wide text-white/80">
          Free shipping on orders over <span style="color: var(--gold);">$75</span> &middot; New arrivals every Friday &middot; Use code <span style="color: var(--gold); font-weight: 500;">STYLE20</span> for 20% off
        </p>
      </div>
    </div>

    <%= render "shared/header" %>

    <% if flash[:notice] %>
      <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
        <div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3">
          <p class="text-sm text-green-800"><%= flash[:notice] %></p>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
        <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm text-red-800"><%= flash[:alert] %></p>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
