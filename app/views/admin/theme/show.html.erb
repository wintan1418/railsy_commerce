<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Appearance</h1>
    <p class="mt-1 text-sm text-gray-500">Customize your store's look and feel without touching code.</p>
  </div>
</div>

<%= form_with url: admin_theme_path, method: :patch, class: "mt-8 space-y-8" do |form| %>
  <% ThemeSetting::GROUPS.each do |group_name| %>
    <% settings = @grouped_settings[group_name] %>
    <% next unless settings %>

    <%
      group_config = {
        "general" => { title: "General", description: "Basic store identity and branding", icon: "M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" },
        "colors" => { title: "Colors", description: "Brand colors used across your storefront", icon: "M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" },
        "hero" => { title: "Hero Section", description: "Main banner on your homepage", icon: "M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" },
        "header" => { title: "Header & Announcement", description: "Top bar and navigation settings", icon: "M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" },
        "footer" => { title: "Footer", description: "Bottom section of your store", icon: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" },
        "social" => { title: "Social Media", description: "Links to your social media profiles", icon: "M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" }
      }
      config = group_config[group_name] || { title: group_name.titleize, description: "", icon: "" }
    %>

    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
      <div class="border-b border-gray-100 px-6 py-4">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg" style="background: rgba(201,169,110,0.1);">
            <svg class="h-5 w-5" style="color: var(--gold, #c9a96e);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= config[:icon] %>" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-900 font-display"><%= config[:title] %></h2>
            <p class="text-xs text-gray-500"><%= config[:description] %></p>
          </div>
        </div>
      </div>

      <div class="px-6 py-5 space-y-5">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <% settings.each do |setting| %>
            <div class="<%= setting.setting_type == 'boolean' ? '' : (setting.description.to_s.length > 80 ? 'sm:col-span-2' : '') %>">
              <% if setting.boolean? %>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="theme[<%= setting.key %>]" value="true"
                    <%= 'checked' if setting.value == 'true' %>
                    class="h-4 w-4 rounded border-gray-300 cursor-pointer" style="accent-color: var(--gold, #c9a96e);">
                  <div>
                    <span class="text-sm font-medium text-gray-700"><%= setting.label %></span>
                    <% if setting.description.present? %>
                      <p class="text-xs text-gray-400"><%= setting.description %></p>
                    <% end %>
                  </div>
                </label>
              <% elsif setting.color? %>
                <label class="block text-sm font-medium text-gray-700"><%= setting.label %></label>
                <% if setting.description.present? %>
                  <p class="mt-0.5 text-xs text-gray-400"><%= setting.description %></p>
                <% end %>
                <div class="mt-1.5 flex items-center gap-3">
                  <input type="color" name="theme[<%= setting.key %>]" value="<%= setting.value || '#c9a96e' %>"
                    class="h-10 w-14 cursor-pointer rounded border border-gray-300 p-0.5">
                  <input type="text" value="<%= setting.value || '#c9a96e' %>"
                    class="block w-32 rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono text-gray-600"
                    readonly>
                </div>
              <% else %>
                <label class="block text-sm font-medium text-gray-700"><%= setting.label %></label>
                <% if setting.description.present? %>
                  <p class="mt-0.5 text-xs text-gray-400"><%= setting.description %></p>
                <% end %>
                <input type="text" name="theme[<%= setting.key %>]" value="<%= setting.value %>"
                  placeholder="<%= setting.description&.truncate(60) %>"
                  class="mt-1.5 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:border-gray-400">
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex justify-end">
    <button type="submit" class="rounded-lg px-8 py-2.5 text-sm font-semibold text-white cursor-pointer transition-colors duration-200 hover:opacity-90" style="background: var(--gold, #c9a96e);">
      Save Appearance
    </button>
  </div>
<% end %>
