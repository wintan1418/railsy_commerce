<!-- Stats -->
<div class="grid grid-cols-3 gap-3">
  <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5 text-center">
    <p class="text-2xl font-bold" style="color: var(--gold);"><%= @completed_today %></p>
    <p class="text-[10px] font-medium uppercase tracking-wider mt-1" style="color: var(--mid-gray);">Today</p>
  </div>
  <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5 text-center">
    <p class="text-2xl font-bold" style="color: var(--black);"><%= @total_completed %></p>
    <p class="text-[10px] font-medium uppercase tracking-wider mt-1" style="color: var(--mid-gray);">Total</p>
  </div>
  <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5 text-center">
    <p class="text-2xl font-bold" style="color: var(--gold);"><%= Money.new(@total_earnings, "USD").format %></p>
    <p class="text-[10px] font-medium uppercase tracking-wider mt-1" style="color: var(--mid-gray);">Earned</p>
  </div>
</div>

<!-- Active Delivery -->
<% if @active_delivery %>
  <div class="mt-6 rounded-xl overflow-hidden shadow-sm ring-1 ring-gray-900/5" style="background: var(--black);">
    <div class="px-5 py-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--gold);">Active Delivery</p>
          <p class="mt-1 text-sm font-semibold text-white"><%= @active_delivery.order.number %></p>
        </div>
        <span class="rounded-full px-3 py-1 text-[10px] font-bold uppercase" style="background: rgba(201,169,110,0.2); color: var(--gold);"><%= @active_delivery.status.humanize %></span>
      </div>
      <% if @active_delivery.order.shipping_address %>
        <div class="mt-3 flex items-start gap-2">
          <svg class="h-4 w-4 mt-0.5 flex-shrink-0" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          <p class="text-sm text-white/60"><%= @active_delivery.order.shipping_address.one_line %></p>
        </div>
      <% end %>
      <div class="mt-4">
        <%= link_to rider_delivery_path(@active_delivery), class: "block w-full rounded-lg py-3 text-center text-sm font-semibold", style: "background: var(--gold); color: var(--black);" do %>
          View & Update
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Available Deliveries -->
<div class="mt-6">
  <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Available Deliveries</h2>
  <% if @available_deliveries.any? %>
    <div class="mt-3 space-y-3">
      <% @available_deliveries.limit(5).each do |delivery| %>
        <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold" style="color: var(--black);"><%= delivery.order.number %></p>
              <p class="text-xs mt-0.5" style="color: var(--mid-gray);"><%= delivery.delivery_address || "Address pending" %></p>
            </div>
            <% if delivery.delivery_fee_cents > 0 %>
              <span class="text-sm font-bold" style="color: var(--gold);"><%= Money.new(delivery.delivery_fee_cents, "USD").format %></span>
            <% end %>
          </div>
          <div class="mt-3">
            <%= link_to rider_delivery_path(delivery), class: "block w-full rounded-lg py-2.5 text-center text-xs font-semibold uppercase tracking-wider", style: "background: var(--cream); color: var(--black);" do %>
              View Details
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mt-3 rounded-xl bg-white p-8 text-center shadow-sm ring-1 ring-gray-900/5">
      <p class="text-sm" style="color: var(--mid-gray);">No deliveries available right now. Check back soon!</p>
    </div>
  <% end %>
</div>
