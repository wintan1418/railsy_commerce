<div class="flex items-center justify-between">
  <h1 class="text-2xl font-bold text-gray-900">Promotions</h1>
  <%= link_to "New Promotion", new_admin_promotion_path, class: "rounded-lg px-4 py-2.5 text-sm font-semibold text-white", style: "background: var(--gold);" %>
</div>

<div class="mt-6 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-100">
      <thead>
        <tr class="bg-gray-50/50">
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Name</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Type</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Conditions</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Dates</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @promotions.each do |promotion| %>
          <tr class="hover:bg-gray-50/50 transition-colors duration-150">
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-gray-900"><%= promotion.name %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 capitalize"><%= promotion.promotion_type.humanize %></td>
            <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate"><%= promotion.conditions.to_json %></td>
            <td class="whitespace-nowrap px-6 py-4">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold <%= promotion.active? ? 'bg-green-50 text-green-700 ring-1 ring-green-600/20' : 'bg-gray-100 text-gray-500 ring-1 ring-gray-300/20' %>">
                <%= promotion.active? ? "Active" : "Inactive" %>
              </span>
              <% if promotion.auto_apply? %>
                <span class="ml-1 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-blue-50 text-blue-700 ring-1 ring-blue-600/20">Auto</span>
              <% end %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500">
              <% if promotion.starts_at.present? || promotion.expires_at.present? %>
                <%= promotion.starts_at&.strftime("%b %d, %Y") || "—" %> to <%= promotion.expires_at&.strftime("%b %d, %Y") || "—" %>
              <% else %>
                Always
              <% end %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm space-x-2">
              <%= link_to "Edit", edit_admin_promotion_path(promotion), class: "font-medium", style: "color: var(--gold);" %>
              <%= button_to "Delete", admin_promotion_path(promotion), method: :delete, data: { turbo_confirm: "Delete this promotion?" }, class: "text-red-500 font-medium cursor-pointer" %>
            </td>
          </tr>
        <% end %>
        <% if @promotions.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">No promotions yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
