<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Order <%= @order.number %></h1>
    <p class="text-sm text-gray-500 mt-1">Placed on <%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
  </div>
  <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium
    <%= case @order.status
        when 'pending' then 'bg-yellow-100 text-yellow-800'
        when 'confirmed' then 'bg-blue-100 text-blue-800'
        when 'processing' then 'bg-purple-100 text-purple-800'
        when 'shipped' then 'bg-indigo-100 text-indigo-800'
        when 'delivered' then 'bg-green-100 text-green-800'
        when 'cancelled' then 'bg-red-100 text-red-800'
        end %>">
    <%= @order.status.capitalize %>
  </span>
</div>

<div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2 space-y-6">
    <!-- Order Items -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900">Items</h2>
      <div class="mt-4 divide-y divide-gray-200">
        <% @order_items.each do |item| %>
          <div class="flex justify-between py-4">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= item.variant.product.name %></p>
              <p class="text-xs text-gray-500">SKU: <%= item.variant.sku || "—" %> | Qty: <%= item.quantity %></p>
            </div>
            <p class="text-sm font-medium text-gray-900"><%= item.total.format %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Update Status -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900">Update Status</h2>
      <%= form_with model: [:admin, @order], class: "mt-4 flex items-end gap-4" do |form| %>
        <div class="flex-1">
          <%= form.select :status, Order.statuses.keys.map { |s| [s.capitalize, s] },
            {}, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
        </div>
        <%= form.submit "Update", class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Customer -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900">Customer</h2>
      <dl class="mt-4 space-y-2">
        <div>
          <dt class="text-xs font-medium text-gray-500">Email</dt>
          <dd class="text-sm text-gray-900"><%= @order.email %></dd>
        </div>
        <% if @order.user %>
          <div>
            <dt class="text-xs font-medium text-gray-500">Name</dt>
            <dd class="text-sm text-gray-900"><%= @order.user.full_name %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Addresses -->
    <% if @order.shipping_address %>
      <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
        <h2 class="text-lg font-semibold text-gray-900">Shipping Address</h2>
        <p class="mt-2 text-sm text-gray-600"><%= @order.shipping_address.one_line %></p>
      </div>
    <% end %>

    <!-- Order Summary -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900">Summary</h2>
      <dl class="mt-4 space-y-2">
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">Subtotal</dt>
          <dd class="text-gray-900"><%= @order.subtotal.format %></dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">Shipping</dt>
          <dd class="text-gray-900"><%= @order.shipping_total.format %></dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">Tax</dt>
          <dd class="text-gray-900"><%= @order.tax_total.format %></dd>
        </div>
        <% if @order.discount_total_cents > 0 %>
          <div class="flex justify-between text-sm">
            <dt class="text-gray-500">Discount</dt>
            <dd class="text-red-600">-<%= @order.discount_total.format %></dd>
          </div>
        <% end %>
        <div class="flex justify-between text-sm font-medium border-t border-gray-200 pt-2 mt-2">
          <dt class="text-gray-900">Total</dt>
          <dd class="text-gray-900"><%= @order.total.format %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<!-- Delivery Assignment -->
<div class="mt-8">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900">Delivery</h2>
    <% if @order.delivery %>
      <div class="mt-4 grid grid-cols-2 gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-gray-500">Status</p>
          <p class="mt-1 text-sm font-semibold capitalize"><%= @order.delivery.status.humanize %></p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-gray-500">Rider</p>
          <p class="mt-1 text-sm"><%= @order.delivery.rider&.full_name || "Unassigned (waiting for rider)" %></p>
        </div>
        <% if @order.delivery.rider_phone.present? %>
          <div>
            <p class="text-xs uppercase tracking-wider text-gray-500">Rider Phone</p>
            <p class="mt-1 text-sm"><%= @order.delivery.rider_phone %></p>
          </div>
        <% end %>
        <% if @order.delivery.delivery_fee_cents > 0 %>
          <div>
            <p class="text-xs uppercase tracking-wider text-gray-500">Delivery Fee</p>
            <p class="mt-1 text-sm"><%= Money.new(@order.delivery.delivery_fee_cents, "USD").format %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-2 text-sm text-gray-500">No delivery assigned yet.</p>
      <%= form_with url: admin_deliveries_path, method: :post, class: "mt-4 space-y-4" do |f| %>
        <%= f.hidden_field :order_id, value: @order.id %>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">Assign Rider (optional)</label>
            <select name="rider_id" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
              <option value="">Leave for riders to accept</option>
              <% User.rider.each do |rider| %>
                <option value="<%= rider.id %>"><%= rider.full_name %> (<%= rider.phone %>)</option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Delivery Fee ($)</label>
            <input type="number" name="delivery_fee" step="0.01" value="5.00" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Pickup Address</label>
            <input type="text" name="pickup_address" value="Main Warehouse" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
          </div>
        </div>
        <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer" style="background: var(--gold); color: var(--black);">
          Create Delivery
        </button>
      <% end %>
    <% end %>
  </div>
</div>
