<%= link_to product_path(product), class: "group" do %>
  <div class="aspect-square w-full overflow-hidden rounded-lg bg-gray-100">
    <% if product.images.attached? %>
      <%= image_tag product.images.first, class: "h-full w-full object-cover object-center group-hover:opacity-75 transition" %>
    <% else %>
      <div class="h-full w-full flex items-center justify-center text-gray-400">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
      </div>
    <% end %>
  </div>
  <div class="mt-3">
    <h3 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600"><%= product.name %></h3>
    <% if product.category %>
      <p class="mt-0.5 text-xs text-gray-500"><%= product.category.name %></p>
    <% end %>
    <div class="mt-1 flex items-center gap-2">
      <% variant = product.master_variant %>
      <% if variant %>
        <% if variant.on_sale? %>
          <span class="text-sm font-medium text-red-600"><%= variant.price.format %></span>
          <span class="text-xs text-gray-400 line-through"><%= variant.compare_at_price.format %></span>
        <% else %>
          <span class="text-sm font-medium text-gray-900"><%= variant.price.format %></span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
