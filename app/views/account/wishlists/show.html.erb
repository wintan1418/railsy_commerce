<div class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
  <h1 class="font-display text-3xl font-light" style="color: var(--black);">My <em class="italic">Wishlist</em></h1>
  <div class="mt-8 grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4">
    <% @items.each do |item| %>
      <div class="rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 overflow-hidden">
        <div class="aspect-square overflow-hidden" style="background: var(--cream);">
          <% if item.variant.product.images.attached? %>
            <%= image_tag item.variant.product.images.first, class: "h-full w-full object-cover" %>
          <% end %>
        </div>
        <div class="p-4">
          <p class="font-display text-sm font-semibold"><%= item.variant.product.name %></p>
          <p class="mt-1 font-display text-sm" style="color: var(--gold);"><%= item.variant.price.format %></p>
          <div class="mt-3 flex gap-2 items-center">
            <%= form_with url: cart_items_path, method: :post, class: "flex-1" do |f| %>
              <%= f.hidden_field :variant_id, value: item.variant.id %>
              <%= f.submit "Add to Cart", class: "w-full rounded py-2 min-h-[44px] text-xs font-semibold text-white cursor-pointer", style: "background: var(--black);" %>
            <% end %>
            <%= button_to "Remove", toggle_account_wishlist_path(variant_id: item.variant.id), method: :post, class: "text-xs text-red-500 cursor-pointer py-2 px-2 min-h-[44px] inline-flex items-center" %>
          </div>
        </div>
      </div>
    <% end %>
    <% if @items.empty? %>
      <div class="col-span-full py-12 text-center">
        <p class="text-sm" style="color: var(--mid-gray);">Your wishlist is empty.</p>
        <%= link_to "Browse Products", products_path, class: "mt-4 inline-block text-sm font-medium", style: "color: var(--gold);" %>
      </div>
    <% end %>
  </div>
</div>
