<%= form_with model: [:admin, discount], class: "space-y-6" do |form| %>
  <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6 space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :code, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :code, required: true, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400" %>
      </div>
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, required: true, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400" %>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :discount_type, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :discount_type, [["Percentage", "percentage"], ["Fixed Amount", "fixed_amount"]], {}, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :amount, class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :amount, step: 0.01, required: true, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none" %>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :starts_at, class: "block text-sm font-medium text-gray-700" %>
        <%= form.datetime_local_field :starts_at, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :expires_at, class: "block text-sm font-medium text-gray-700" %>
        <%= form.datetime_local_field :expires_at, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= form.label :usage_limit, class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :usage_limit, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :per_user_limit, class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :per_user_limit, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :minimum_order_cents, "Min Order (cents)", class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :minimum_order_cents, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= form.check_box :active, class: "h-4 w-4 rounded border-gray-300" %>
      <%= form.label :active, "Active", class: "text-sm font-medium text-gray-700" %>
    </div>
  </div>
  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", admin_discounts_path, class: "rounded-lg bg-white border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700" %>
    <%= form.submit discount.persisted? ? "Update" : "Create Discount", class: "rounded-lg px-4 py-2 text-sm font-semibold text-white cursor-pointer", style: "background: var(--gold);" %>
  </div>
<% end %>
