<div class="group relative rounded-lg overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1" style="background: white;">
  <!-- Image -->
  <div class="relative aspect-square w-full overflow-hidden" style="background: var(--cream);">
    <% if product.images.attached? %>
      <%= image_tag product.images.first, class: "product-card-image h-full w-full object-cover object-center" %>
    <% else %>
      <div class="flex h-full w-full items-center justify-center" style="color: var(--light-gray);">
        <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
      </div>
    <% end %>

    <!-- Sale Badge -->
    <% variant = product.master_variant %>
    <% if variant&.on_sale? %>
      <div class="absolute left-3 top-3">
        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold text-white" style="background: var(--red);">
          Sale
        </span>
      </div>
    <% end %>

    <!-- Hover Actions -->
    <div class="product-card-actions absolute right-3 top-3 flex flex-col gap-2 sm:translate-x-2 sm:opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100">
      <!-- Wishlist Heart -->
      <% if authenticated? %>
        <% wishlisted = current_user.wishlist&.includes_variant?(variant) %>
        <%= button_to toggle_account_wishlist_path(variant_id: variant.id), method: :post,
          class: "flex h-9 w-9 items-center justify-center rounded-full bg-white shadow-sm transition-all duration-200 hover:scale-110 cursor-pointer",
          style: wishlisted ? "color: var(--red);" : "color: var(--mid-gray);",
          title: wishlisted ? "Remove from Wishlist" : "Add to Wishlist" do %>
          <svg class="h-4 w-4" fill="<%= wishlisted ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        <% end %>
      <% else %>
        <%= link_to new_session_path, class: "flex h-9 w-9 items-center justify-center rounded-full bg-white shadow-sm transition-all duration-200 hover:scale-110", style: "color: var(--mid-gray);", title: "Sign in to save" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        <% end %>
      <% end %>
      <!-- Quick View -->
      <%= link_to product_path(product), class: "flex h-9 w-9 items-center justify-center rounded-full bg-white shadow-sm transition-all duration-200 hover:scale-110", style: "color: var(--mid-gray);", title: "Quick View" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      <% end %>
    </div>
  </div>

  <!-- Product Info -->
  <div class="p-4">
    <% if product.category %>
      <p class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--gold);"><%= product.category.name %></p>
    <% end %>

    <h3 class="mt-1">
      <%= link_to product.name, product_path(product),
        class: "font-display text-base font-semibold transition-colors duration-200 hover:opacity-70",
        style: "color: var(--black);" %>
    </h3>

    <!-- Star Rating -->
    <div class="mt-1.5 flex items-center gap-1">
      <div class="flex" style="color: var(--gold);">
        <% rating = product.average_rating || 4.5 %>
        <% 5.times do |i| %>
          <% if i < rating.floor %>
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/></svg>
          <% elsif i < rating %>
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" opacity="0.5"/></svg>
          <% else %>
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" style="color: var(--light-gray);"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/></svg>
          <% end %>
        <% end %>
      </div>
      <span class="text-xs" style="color: var(--mid-gray);">(<%= product.reviews_count %>)</span>
    </div>

    <!-- Price -->
    <div class="mt-2 flex items-center gap-2">
      <% if variant %>
        <% if variant.on_sale? %>
          <span class="font-display text-lg font-semibold" style="color: var(--red);"><%= variant.price.format %></span>
          <span class="text-xs line-through" style="color: var(--mid-gray);"><%= variant.compare_at_price.format %></span>
        <% else %>
          <span class="font-display text-lg font-semibold" style="color: var(--black);"><%= variant.price.format %></span>
        <% end %>
      <% end %>
    </div>

    <!-- Add to Cart Button -->
    <% if variant && product.in_stock? %>
      <div class="mt-3">
        <%= form_with url: cart_items_path, method: :post do |form| %>
          <%= form.hidden_field :variant_id, value: variant.id %>
          <%= form.hidden_field :quantity, value: 1 %>
          <%= form.submit "Add to Cart",
            class: "w-full cursor-pointer rounded-md py-2.5 min-h-[44px] text-xs font-semibold uppercase tracking-wider text-white transition-all duration-200",
            style: "background: var(--black);",
            onmouseover: "this.style.background='var(--gold)'; this.style.color='var(--black)';",
            onmouseout: "this.style.background='var(--black)'; this.style.color='white';" %>
        <% end %>
      </div>
    <% end %>

    <!-- Compare Checkbox -->
    <div class="mt-2 flex items-center gap-1.5">
      <input type="checkbox"
        data-compare-target="checkbox"
        data-action="compare#toggle"
        data-product-id="<%= product.id %>"
        class="h-3.5 w-3.5 rounded border-gray-300 cursor-pointer accent-[var(--gold)]">
      <label class="text-[11px]" style="color: var(--mid-gray);">Compare</label>
    </div>
  </div>
</div>
