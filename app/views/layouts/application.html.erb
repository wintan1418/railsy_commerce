<!DOCTYPE html>
<html class="h-full scroll-smooth">
  <head>
    <title><%= content_for(:title) || "RailsyCommerce" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full antialiased">
    <!-- Announcement Ticker -->
    <div class="relative overflow-hidden" style="background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);" data-controller="ticker">
      <div class="mx-auto max-w-7xl px-4 py-2 sm:px-6 lg:px-8">
        <div class="relative h-5 overflow-hidden">
          <% [
            "Free shipping on all orders over <strong>$75</strong> — no code needed",
            "New products added daily — <strong>Explore what's new</strong>",
            "Use code <strong>WELCOME20</strong> for 20% off your first order"
          ].each_with_index do |msg, i| %>
            <p data-ticker-target="message"
               class="absolute inset-0 flex items-center justify-center text-center text-xs font-medium tracking-wide transition-all duration-500 <%= i == 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-full' %>"
               style="color: var(--black);">
              <%= raw msg %>
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <%= render "shared/header" %>

    <% if flash[:notice] %>
      <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
        <div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3">
          <p class="text-sm text-green-800"><%= flash[:notice] %></p>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
        <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm text-red-800"><%= flash[:alert] %></p>
        </div>
      </div>
    <% end %>

    <main class="w-full max-w-none flex-1">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
