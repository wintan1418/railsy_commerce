<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div class="text-center">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900">Sign in</h1>
      <p class="mt-2 text-sm text-gray-600">
        Don't have an account?
        <%= link_to "Create one", new_registration_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
      </p>
    </div>

    <% if flash[:alert] %>
      <div class="rounded-md bg-red-50 p-4">
        <p class="text-sm text-red-700"><%= flash[:alert] %></p>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="rounded-md bg-green-50 p-4">
        <p class="text-sm text-green-700"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <%= form_with url: session_path, class: "mt-8 space-y-6" do |form| %>
      <div class="space-y-4">
        <div>
          <%= form.label :email_address, "Email address", class: "block text-sm font-medium text-gray-700" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            value: params[:email_address],
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
        </div>

        <div>
          <div class="flex items-center justify-between">
            <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
            <%= link_to "Forgot password?", new_password_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
          </div>
          <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72,
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <%= form.submit "Sign in",
        class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
    <% end %>
  </div>
</div>
