<div class="flex py-6 gap-6" id="<%= dom_id(cart_item) %>">
  <div class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-lg bg-gray-100">
    <% if cart_item.variant.product.images.attached? %>
      <%= image_tag cart_item.variant.product.images.first, class: "h-full w-full object-cover" %>
    <% end %>
  </div>

  <div class="flex flex-1 flex-col">
    <div class="flex justify-between">
      <div>
        <h3 class="text-sm font-medium text-gray-900">
          <%= link_to cart_item.variant.product.name, product_path(cart_item.variant.product), class: "hover:text-indigo-600" %>
        </h3>
        <% if cart_item.variant.option_values.any? %>
          <p class="mt-1 text-xs text-gray-500"><%= cart_item.variant.options_text %></p>
        <% end %>
      </div>
      <span class="text-sm font-medium text-gray-900"><%= cart_item.subtotal.format %></span>
    </div>

    <div class="mt-auto flex items-center justify-between pt-2">
      <%= form_with url: cart_item_path(cart_item), method: :patch, class: "flex items-center gap-2" do |form| %>
        <%= form.number_field "cart_item[quantity]", value: cart_item.quantity, min: 1, max: 99,
          class: "w-16 rounded border border-gray-300 px-2 py-1 text-center text-sm focus:border-indigo-500 focus:outline-none",
          onchange: "this.form.requestSubmit()" %>
      <% end %>

      <%= button_to cart_item_path(cart_item), method: :delete, class: "text-sm text-red-600 hover:text-red-500 cursor-pointer" do %>
        Remove
      <% end %>
    </div>
  </div>
</div>
