<footer style="background: var(--black);">
  <!-- Gold gradient top border -->
  <div class="footer-top-border"></div>

  <!-- Main Footer -->
  <div class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-12">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-5">
          <div class="flex h-8 w-8 items-center justify-center rounded" style="background: rgba(201,169,110,0.15);">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none">
              <rect x="2" y="2" width="7" height="7" rx="1" fill="var(--gold)"/>
              <rect x="11" y="2" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.7"/>
              <rect x="2" y="11" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.7"/>
              <rect x="11" y="11" width="7" height="7" rx="1" fill="var(--gold)" opacity="0.4"/>
            </svg>
          </div>
          <span class="font-display text-lg font-semibold text-white">RailsyCommerce</span>
        </div>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.4);">
          Your one-stop marketplace for everything — from electronics to home essentials, fashion to fitness. Quality products, exceptional service.
        </p>
        <!-- Social Links -->
        <div class="mt-6 flex gap-3">
          <a href="#" class="social-icon flex h-9 w-9 items-center justify-center rounded-full border" style="border-color: rgba(255,255,255,0.12); color: rgba(255,255,255,0.4);" aria-label="Twitter">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="social-icon flex h-9 w-9 items-center justify-center rounded-full border" style="border-color: rgba(255,255,255,0.12); color: rgba(255,255,255,0.4);" aria-label="Instagram">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="social-icon flex h-9 w-9 items-center justify-center rounded-full border" style="border-color: rgba(255,255,255,0.12); color: rgba(255,255,255,0.4);" aria-label="Facebook">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="social-icon flex h-9 w-9 items-center justify-center rounded-full border" style="border-color: rgba(255,255,255,0.12); color: rgba(255,255,255,0.4);" aria-label="YouTube">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Shop -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Shop</h3>
        <div class="mt-1 h-px w-8" style="background: var(--gold); opacity: 0.4;"></div>
        <ul class="mt-5 space-y-3">
          <li><%= link_to "All Products", products_path, class: "text-sm transition-colors duration-200 hover:text-[var(--gold)]", style: "color: rgba(255,255,255,0.4);" %></li>
          <li><%= link_to "New Arrivals", products_path(sort: "newest"), class: "text-sm transition-colors duration-200 hover:text-[var(--gold)]", style: "color: rgba(255,255,255,0.4);" %></li>
          <li><%= link_to "On Sale", products_path(on_sale: true), class: "text-sm transition-colors duration-200 hover:text-[var(--gold)]", style: "color: rgba(255,255,255,0.4);" %></li>
          <% Category.active.roots.ordered.limit(4).each do |cat| %>
            <li><%= link_to cat.name, category_path(slug: cat.slug), class: "text-sm transition-colors duration-200 hover:text-[var(--gold)]", style: "color: rgba(255,255,255,0.4);" %></li>
          <% end %>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Support</h3>
        <div class="mt-1 h-px w-8" style="background: var(--gold); opacity: 0.4;"></div>
        <ul class="mt-5 space-y-3">
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Contact Us</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Shipping & Returns</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">FAQ</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Order Tracking</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Warranty Info</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Company</h3>
        <div class="mt-1 h-px w-8" style="background: var(--gold); opacity: 0.4;"></div>
        <ul class="mt-5 space-y-3">
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">About Us</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Careers</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Press</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Sustainability</a></li>
          <li><a href="#" class="text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.4);">Affiliates</a></li>
          <li><%= link_to "Hire a Developer", hire_path, class: "text-sm transition-colors duration-200 hover:text-[var(--gold)]", style: "color: rgba(255,255,255,0.4);" %></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t" style="border-color: rgba(255,255,255,0.06);">
    <div class="mx-auto max-w-7xl px-6 py-6 sm:px-8 lg:px-12">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs" style="color: rgba(255,255,255,0.2);">&copy; <%= Date.current.year %> RailsyCommerce. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="#" class="text-xs transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.2);">Privacy Policy</a>
          <a href="#" class="text-xs transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.2);">Terms of Service</a>
          <a href="#" class="text-xs transition-colors duration-200 hover:text-[var(--gold)]" style="color: rgba(255,255,255,0.2);">Cookie Settings</a>
        </div>
      </div>
    </div>
  </div>
</footer>
