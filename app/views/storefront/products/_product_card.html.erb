<div class="group relative">
  <!-- Image -->
  <div class="relative aspect-square w-full overflow-hidden rounded-xl bg-gray-100">
    <% if product.images.attached? %>
      <%= image_tag product.images.first, class: "h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105" %>
    <% else %>
      <div class="flex h-full w-full items-center justify-center text-gray-300">
        <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
      </div>
    <% end %>

    <!-- Sale Badge -->
    <% variant = product.master_variant %>
    <% if variant&.on_sale? %>
      <div class="absolute left-3 top-3">
        <span class="inline-flex items-center rounded-full bg-red-500 px-2.5 py-1 text-xs font-bold text-white shadow-sm">
          Sale
        </span>
      </div>
    <% end %>

    <!-- Wishlist Heart -->
    <button type="button" class="absolute right-3 top-3 rounded-full bg-white/80 p-2 text-gray-400 opacity-0 shadow-sm backdrop-blur-sm transition-all duration-200 hover:bg-white hover:text-red-500 group-hover:opacity-100">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
    </button>

    <!-- Quick Add Button -->
    <% if variant && product.in_stock? %>
      <div class="absolute inset-x-3 bottom-3 translate-y-2 opacity-0 transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100">
        <%= form_with url: cart_items_path, method: :post do |form| %>
          <%= form.hidden_field :variant_id, value: variant.id %>
          <%= form.hidden_field :quantity, value: 1 %>
          <%= form.submit "Add to Cart",
            class: "w-full cursor-pointer rounded-lg bg-indigo-600 py-2.5 text-sm font-semibold text-white shadow-lg hover:bg-indigo-700 transition-colors duration-200" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Product Info -->
  <div class="mt-4">
    <% if product.category %>
      <p class="text-xs font-medium uppercase tracking-wider text-gray-400"><%= product.category.name %></p>
    <% end %>

    <h3 class="mt-1">
      <%= link_to product.name, product_path(product),
        class: "text-sm font-medium text-gray-900 hover:text-indigo-600 transition-colors duration-200" %>
    </h3>

    <!-- Star Rating -->
    <div class="mt-1.5 flex items-center gap-1">
      <div class="flex text-amber-400">
        <% rating = [4, 4.5, 5].sample %>
        <% 5.times do |i| %>
          <% if i < rating.floor %>
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/></svg>
          <% elsif i < rating %>
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" opacity="0.5"/></svg>
          <% else %>
            <svg class="h-3.5 w-3.5 text-gray-200" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/></svg>
          <% end %>
        <% end %>
      </div>
      <span class="text-xs text-gray-400">(<%= rand(12..248) %>)</span>
    </div>

    <!-- Price -->
    <div class="mt-2 flex items-center gap-2">
      <% if variant %>
        <% if variant.on_sale? %>
          <span class="text-sm font-bold text-red-600"><%= variant.price.format %></span>
          <span class="text-xs text-gray-400 line-through"><%= variant.compare_at_price.format %></span>
        <% else %>
          <span class="text-sm font-bold text-gray-900"><%= variant.price.format %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
