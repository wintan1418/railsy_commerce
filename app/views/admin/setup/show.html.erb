<div class="mx-auto max-w-2xl">
  <!-- Header -->
  <div class="text-center mb-10">
    <div class="flex items-center justify-center gap-2 mb-4">
      <svg class="h-8 w-8 text-indigo-400" viewBox="0 0 32 32" fill="currentColor">
        <rect x="2" y="2" width="12" height="12" rx="3"/>
        <rect x="18" y="2" width="12" height="12" rx="3" opacity="0.7"/>
        <rect x="2" y="18" width="12" height="12" rx="3" opacity="0.7"/>
        <rect x="18" y="18" width="12" height="12" rx="3" opacity="0.4"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 font-display">Set Up Your Store</h1>
    <p class="mt-2 text-sm text-gray-500">Let's get your store ready in just a few minutes.</p>
  </div>

  <!-- Step Indicators -->
  <div class="flex items-center justify-center gap-2 mb-10">
    <% step_labels = ["Basics", "Payment", "Shipping", "Appearance", "Done"] %>
    <% step_labels.each_with_index do |label, i| %>
      <% step_num = i + 1 %>
      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-full text-xs font-bold
          <%= if step_num < @step
                'bg-green-500 text-white'
              elsif step_num == @step
                'text-white'
              else
                'bg-gray-200 text-gray-400'
              end %>"
          <% if step_num == @step %>style="background: var(--gold, #c9a96e);"<% end %>>
          <% if step_num < @step %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          <% else %>
            <%= step_num %>
          <% end %>
        </div>
        <span class="hidden sm:block text-xs font-medium <%= step_num == @step ? 'text-gray-900' : 'text-gray-400' %>"><%= label %></span>
        <% if i < step_labels.length - 1 %>
          <div class="h-px w-6 sm:w-10 <%= step_num < @step ? 'bg-green-300' : 'bg-gray-200' %>"></div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Step Content -->
  <% if @step == 1 %>
    <!-- Step 1: Store Basics -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900 font-display">Store Basics</h2>
      <p class="mt-1 text-sm text-gray-500">Tell us about your store. You can change these later in Settings.</p>

      <%= form_with url: admin_setup_path, method: :patch, class: "mt-6 space-y-5" do |form| %>
        <input type="hidden" name="step" value="1">

        <div>
          <label class="block text-sm font-medium text-gray-700">Store Name</label>
          <input type="text" name="store_name" value="<%= StoreConfig.get('store_name') %>" placeholder="My Awesome Store"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Contact Email</label>
          <input type="email" name="store_email" value="<%= StoreConfig.get('store_email') %>" placeholder="hello@mystore.com"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Currency</label>
          <select name="store_currency" class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm">
            <% %w[USD EUR GBP CAD AUD NGN JPY].each do |c| %>
              <option value="<%= c %>" <%= 'selected' if StoreConfig.get('store_currency') == c %>><%= c %></option>
            <% end %>
          </select>
        </div>

        <div class="flex justify-between pt-4">
          <span></span>
          <div class="flex gap-3">
            <%= link_to "Skip", admin_setup_path(step: 2), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
            <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer hover:opacity-90 transition-colors" style="background: var(--gold, #c9a96e);">
              Continue
            </button>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @step == 2 %>
    <!-- Step 2: Payment -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900 font-display">Payment Setup</h2>
      <p class="mt-1 text-sm text-gray-500">Connect Stripe to accept payments. Get your keys from <a href="https://dashboard.stripe.com/apikeys" target="_blank" class="underline" style="color: var(--gold, #c9a96e);">Stripe Dashboard</a>.</p>

      <%= form_with url: admin_setup_path, method: :patch, class: "mt-6 space-y-5" do |form| %>
        <input type="hidden" name="step" value="2">

        <div>
          <label class="block text-sm font-medium text-gray-700">Stripe Publishable Key</label>
          <input type="text" name="stripe_publishable_key" placeholder="pk_test_..." value="<%= StoreConfig.get('stripe_publishable_key') %>"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-mono focus:outline-none focus:ring-1">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Stripe Secret Key</label>
          <input type="password" name="stripe_secret_key" placeholder="sk_test_..." value="<%= StoreConfig.get('stripe_secret_key') %>"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-mono focus:outline-none focus:ring-1">
        </div>

        <div class="rounded-lg bg-blue-50 border border-blue-200 p-4">
          <p class="text-xs text-blue-700">You can also set Stripe keys via environment variables (<code>STRIPE_PUBLISHABLE_KEY</code> and <code>STRIPE_SECRET_KEY</code>). Environment variables take priority.</p>
        </div>

        <div class="flex justify-between pt-4">
          <%= link_to "Back", admin_setup_path(step: 1), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
          <div class="flex gap-3">
            <%= link_to "Skip", admin_setup_path(step: 3), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
            <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer hover:opacity-90 transition-colors" style="background: var(--gold, #c9a96e);">
              Continue
            </button>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @step == 3 %>
    <!-- Step 3: Shipping -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900 font-display">Shipping</h2>
      <p class="mt-1 text-sm text-gray-500">Create your first shipping method. You can add more later in the admin panel.</p>

      <%= form_with url: admin_setup_path, method: :patch, class: "mt-6 space-y-5" do |form| %>
        <input type="hidden" name="step" value="3">

        <div>
          <label class="block text-sm font-medium text-gray-700">Shipping Method Name</label>
          <input type="text" name="shipping_name" value="Standard Shipping" placeholder="e.g., Standard Shipping"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Price ($)</label>
          <input type="number" name="shipping_price" value="9.99" step="0.01" min="0"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Min Delivery Days</label>
            <input type="number" name="min_days" value="5" min="1"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Max Delivery Days</label>
            <input type="number" name="max_days" value="7" min="1"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
          </div>
        </div>

        <div class="flex justify-between pt-4">
          <%= link_to "Back", admin_setup_path(step: 2), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
          <div class="flex gap-3">
            <%= link_to "Skip", admin_setup_path(step: 4), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
            <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer hover:opacity-90 transition-colors" style="background: var(--gold, #c9a96e);">
              Continue
            </button>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @step == 4 %>
    <!-- Step 4: Appearance -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
      <h2 class="text-lg font-semibold text-gray-900 font-display">Appearance</h2>
      <p class="mt-1 text-sm text-gray-500">Set your brand colors and logo. Fine-tune everything later in Appearance settings.</p>

      <%= form_with url: admin_setup_path, method: :patch, class: "mt-6 space-y-5" do |form| %>
        <input type="hidden" name="step" value="4">

        <div>
          <label class="block text-sm font-medium text-gray-700">Logo URL</label>
          <input type="url" name="logo_url" value="<%= ThemeSetting.get('logo_url') %>" placeholder="https://example.com/logo.png"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-1">
          <p class="mt-1 text-xs text-gray-400">Paste a URL to your store logo image</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Primary Brand Color</label>
          <div class="mt-1.5 flex items-center gap-3">
            <input type="color" name="primary_color" value="<%= ThemeSetting.get('primary_color', '#c9a96e') %>"
              class="h-10 w-14 cursor-pointer rounded border border-gray-300 p-0.5">
            <span class="text-sm text-gray-500">This color is used for buttons, links, and accents</span>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Secondary Color</label>
          <div class="mt-1.5 flex items-center gap-3">
            <input type="color" name="secondary_color" value="<%= ThemeSetting.get('secondary_color', '#1a1a1a') %>"
              class="h-10 w-14 cursor-pointer rounded border border-gray-300 p-0.5">
            <span class="text-sm text-gray-500">Used for headings and dark backgrounds</span>
          </div>
        </div>

        <div class="flex justify-between pt-4">
          <%= link_to "Back", admin_setup_path(step: 3), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
          <div class="flex gap-3">
            <%= link_to "Skip", admin_setup_path(step: 5), class: "rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
            <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer hover:opacity-90 transition-colors" style="background: var(--gold, #c9a96e);">
              Continue
            </button>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @step == 5 %>
    <!-- Step 5: Done! -->
    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-8 text-center">
      <div class="flex justify-center mb-4">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
          <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-gray-900 font-display">Your Store is Ready!</h2>
      <p class="mt-2 text-sm text-gray-500">Congratulations! You've completed the basic setup. Here's what you can do next:</p>

      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 text-left">
        <a href="<%= admin_products_path %>" class="rounded-lg border border-gray-200 p-4 hover:border-gray-300 transition-colors">
          <h3 class="text-sm font-semibold text-gray-900">Add Products</h3>
          <p class="mt-1 text-xs text-gray-500">Start listing your products for sale</p>
        </a>
        <a href="<%= admin_theme_path %>" class="rounded-lg border border-gray-200 p-4 hover:border-gray-300 transition-colors">
          <h3 class="text-sm font-semibold text-gray-900">Customize Appearance</h3>
          <p class="mt-1 text-xs text-gray-500">Fine-tune colors, hero section, and more</p>
        </a>
        <a href="<%= admin_pages_path %>" class="rounded-lg border border-gray-200 p-4 hover:border-gray-300 transition-colors">
          <h3 class="text-sm font-semibold text-gray-900">Edit Pages</h3>
          <p class="mt-1 text-xs text-gray-500">Update About, FAQ, and policy pages</p>
        </a>
        <a href="<%= root_path %>" target="_blank" class="rounded-lg border border-gray-200 p-4 hover:border-gray-300 transition-colors">
          <h3 class="text-sm font-semibold text-gray-900">View Your Store</h3>
          <p class="mt-1 text-xs text-gray-500">See how your store looks to customers</p>
        </a>
      </div>

      <div class="mt-8">
        <%= form_with url: admin_setup_path, method: :patch do %>
          <input type="hidden" name="step" value="5">
          <button type="submit" class="rounded-lg px-8 py-3 text-sm font-semibold text-white cursor-pointer hover:opacity-90 transition-colors" style="background: var(--gold, #c9a96e);">
            Go to Dashboard
          </button>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
