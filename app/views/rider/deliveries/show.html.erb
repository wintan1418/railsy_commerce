<%= link_to "← Back", rider_deliveries_path, class: "text-sm font-medium", style: "color: var(--gold);" %>

<div class="mt-4 rounded-xl overflow-hidden shadow-sm ring-1 ring-gray-900/5" style="background: var(--black);">
  <div class="px-5 py-5">
    <div class="flex items-center justify-between">
      <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--gold);">Order <%= @delivery.order.number %></p>
      <span class="rounded-full px-3 py-1 text-[10px] font-bold uppercase" style="background: rgba(201,169,110,0.2); color: var(--gold);"><%= @delivery.status.humanize %></span>
    </div>
    <% if @delivery.order.user %>
      <p class="mt-2 text-sm text-white"><%= @delivery.order.user.full_name %></p>
      <p class="text-xs text-white/40"><%= @delivery.order.email %></p>
    <% end %>
    <% if @delivery.delivery_fee_cents > 0 %>
      <p class="mt-2 text-lg font-bold" style="color: var(--gold);">Fee: <%= Money.new(@delivery.delivery_fee_cents, "USD").format %></p>
    <% end %>
  </div>
</div>

<!-- Addresses -->
<div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
  <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--gold);">Pickup</p>
    <p class="mt-1 text-sm" style="color: var(--black);"><%= @delivery.pickup_address || "Warehouse" %></p>
  </div>
  <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--gold);">Deliver To</p>
    <p class="mt-1 text-sm" style="color: var(--black);"><%= @delivery.delivery_address || @delivery.order.shipping_address&.one_line || "TBD" %></p>
  </div>
</div>

<!-- Action Buttons -->
<div class="mt-6 space-y-3">
  <% case @delivery.status %>
  <% when "pending" %>
    <%= button_to "Accept This Delivery", accept_rider_delivery_path(@delivery), method: :post,
      class: "w-full rounded-xl py-4 text-sm font-bold uppercase tracking-wider text-center cursor-pointer min-h-[52px]",
      style: "background: var(--gold); color: var(--black);" %>
  <% when "assigned", "accepted" %>
    <%= button_to "Picked Up Package", pick_up_rider_delivery_path(@delivery), method: :post,
      class: "w-full rounded-xl py-4 text-sm font-bold uppercase tracking-wider text-center cursor-pointer min-h-[52px]",
      style: "background: var(--gold); color: var(--black);" %>
  <% when "picked_up" %>
    <%= button_to "On My Way (In Transit)", in_transit_rider_delivery_path(@delivery), method: :post,
      class: "w-full rounded-xl py-4 text-sm font-bold uppercase tracking-wider text-center cursor-pointer min-h-[52px]",
      style: "background: var(--gold); color: var(--black);" %>
  <% when "in_transit" %>
    <%= button_to "Mark as Delivered", complete_rider_delivery_path(@delivery), method: :post,
      data: { turbo_confirm: "Confirm this delivery is complete?" },
      class: "w-full rounded-xl py-4 text-sm font-bold uppercase tracking-wider text-center cursor-pointer min-h-[52px]",
      style: "background: #2e7d32; color: white;" %>
  <% when "delivered" %>
    <div class="rounded-xl bg-green-50 p-4 text-center">
      <svg class="mx-auto h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <p class="mt-2 text-sm font-semibold text-green-700">Delivered!</p>
      <p class="text-xs text-green-600"><%= @delivery.delivered_at&.strftime("%b %d at %I:%M %p") %></p>
    </div>
  <% end %>
</div>

<!-- Rider Notes -->
<% if @delivery.rider_notes.present? %>
  <div class="mt-4 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-900/5">
    <p class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--mid-gray);">Notes</p>
    <p class="mt-1 text-sm" style="color: var(--text-body);"><%= @delivery.rider_notes %></p>
  </div>
<% end %>

<!-- Tracking Timeline -->
<% if @tracking_updates.any? %>
  <div class="mt-6 rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
    <h3 class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--mid-gray);">Timeline</h3>
    <div class="relative pl-6">
      <div class="absolute left-2 top-2 bottom-2 w-0.5" style="background: var(--cream);"></div>
      <% @tracking_updates.reverse.each_with_index do |update, idx| %>
        <div class="relative pb-4 last:pb-0">
          <div class="absolute -left-4 top-1 flex h-3 w-3 items-center justify-center rounded-full" style="background: <%= idx == 0 ? 'var(--gold)' : 'var(--cream)' %>;"></div>
          <p class="text-xs font-semibold" style="color: var(--black);"><%= update.friendly_status %></p>
          <p class="text-[10px]" style="color: var(--mid-gray);"><%= update.created_at.strftime("%b %d, %I:%M %p") %></p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
