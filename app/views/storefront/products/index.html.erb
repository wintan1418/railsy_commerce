<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">
      <% if params[:q].present? %>
        Search results for "<%= params[:q] %>"
      <% else %>
        All Products
      <% end %>
    </h1>
  </div>

  <!-- Categories filter -->
  <div class="mt-4 flex flex-wrap gap-2">
    <%= link_to "All", products_path, class: "px-3 py-1.5 text-sm rounded-full #{params[:category_id].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% @categories.each do |category| %>
      <%= link_to category.name, products_path(category_id: category.id),
        class: "px-3 py-1.5 text-sm rounded-full #{params[:category_id].to_s == category.id.to_s ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% end %>
  </div>

  <% if @products.any? %>
    <div class="mt-8 grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-3 lg:grid-cols-4">
      <% @products.each do |product| %>
        <%= render "storefront/products/product_card", product: product %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-16 text-center">
      <p class="text-gray-500">No products found.</p>
    </div>
  <% end %>
</div>
