<div class="rounded-xl p-6 lg:p-8" style="background-color: white; border: 1px solid var(--light-gray);">
  <h2 class="font-display text-2xl font-semibold mb-2" style="color: var(--black);">Payment</h2>
  <p class="text-sm mb-8" style="color: var(--mid-gray);">Review your order and complete your purchase.</p>

  <!-- Order Review -->
  <div class="mb-8 rounded-lg p-4" style="background-color: var(--cream);">
    <h3 class="text-sm font-semibold mb-3" style="color: var(--black);">Shipping to</h3>
    <% if session[:checkout_shipping_address_id] %>
      <% address = Address.find(session[:checkout_shipping_address_id]) %>
      <p class="text-sm" style="color: var(--text-body);"><%= address.full_name %></p>
      <p class="text-sm" style="color: var(--mid-gray);"><%= address.one_line %></p>
    <% end %>

    <% if local_assigns[:shipping_method] && shipping_method %>
      <h3 class="text-sm font-semibold mt-4 mb-1" style="color: var(--black);">Shipping method</h3>
      <p class="text-sm" style="color: var(--mid-gray);">
        <%= shipping_method.name %>
        <% if shipping_method.delivery_estimate %>
          &mdash; <%= shipping_method.delivery_estimate %>
        <% end %>
      </p>
    <% end %>
  </div>

  <!-- Card Payment Section -->
  <div class="mb-8">
    <h3 class="text-sm font-semibold mb-4" style="color: var(--black);">Card Details</h3>
    <div class="rounded-lg p-5" style="border: 1px solid var(--light-gray);">
      <div class="flex items-center gap-2 mb-4">
        <svg class="h-8 w-auto" viewBox="0 0 48 32" fill="none"><rect width="48" height="32" rx="4" fill="#1A1F71"/><path d="M19.5 20.5l2-9h3l-2 9h-3zm12-9l-2.8 6.2-.3-1.5-.9-4.7h-3.2l4 9h3l5-9h-2.8zm-17 0l-3 6.2-.3-1.5L10.3 11.5h-4l-.3.2 4.5 9h3l4.5-9H14.5z" fill="#fff"/></svg>
        <svg class="h-8 w-auto" viewBox="0 0 48 32" fill="none"><rect width="48" height="32" rx="4" fill="#252525"/><circle cx="20" cy="16" r="8" fill="#EB001B"/><circle cx="28" cy="16" r="8" fill="#F79E1B"/><path d="M24 10.3a8 8 0 010 11.4 8 8 0 000-11.4z" fill="#FF5F00"/></svg>
        <span class="ml-auto text-xs" style="color: var(--mid-gray);">Secured by Stripe</span>
      </div>

      <!-- Stripe Elements mount point -->
      <div id="stripe-card-element"
           data-controller="stripe-payment"
           data-stripe-payment-key-value="<%= ENV['STRIPE_PUBLISHABLE_KEY'] %>"
           class="rounded-lg p-4 transition-colors"
           style="border: 1px solid var(--light-gray); background: var(--warm-white); min-height: 44px;">
      </div>
      <div id="card-errors" class="mt-2 text-xs text-red-600" role="alert"></div>
    </div>
  </div>

  <!-- Security badges -->
  <div class="mb-8 flex items-center justify-center gap-6">
    <div class="flex items-center gap-2 text-xs" style="color: var(--mid-gray);">
      <svg class="h-4 w-4" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
      </svg>
      SSL Encrypted
    </div>
    <div class="flex items-center gap-2 text-xs" style="color: var(--mid-gray);">
      <svg class="h-4 w-4" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
      </svg>
      PCI Compliant
    </div>
  </div>

  <%= form_with url: checkout_path, method: :patch, id: "payment-form" do |f| %>
    <%= f.hidden_field :step, value: "payment" %>

    <div class="flex gap-4">
      <%= link_to checkout_path, class: "flex-1 rounded-lg px-6 py-3.5 text-center text-sm font-medium tracking-wide transition-all duration-300 hover:opacity-75", style: "border: 1px solid var(--light-gray); color: var(--black);" do %>
        Back
      <% end %>
      <button type="submit" id="submit-payment"
        class="flex-1 rounded-lg px-6 py-3.5 text-sm font-semibold tracking-wide uppercase transition-all duration-300 hover:opacity-90 cursor-pointer"
        style="background-color: var(--gold); color: var(--black);">
        Pay & Place Order
      </button>
    </div>
  <% end %>
</div>
