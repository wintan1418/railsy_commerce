<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <div style="padding: 40px 20px; text-align: center; background-color: #0a0a0a;">
    <h1 style="color: #c9a96e; font-family: 'Georgia', serif; font-size: 24px; margin: 0;">RailsyCommerce</h1>
  </div>

  <div style="padding: 40px 30px; background-color: #ffffff;">
    <h2 style="color: #0a0a0a; font-family: 'Georgia', serif; font-size: 22px; margin-bottom: 10px;">You left something behind</h2>
    <p style="color: #6b7280; font-size: 15px; line-height: 1.6; margin-bottom: 30px;">
      Hi <%= @user.first_name %>, we noticed you left some items in your cart.
      Complete your purchase before they sell out!
    </p>

    <% @cart_items.each do |item| %>
      <div style="display: flex; align-items: center; padding: 16px 0; border-bottom: 1px solid #f3f4f6;">
        <div style="width: 70px; height: 70px; border-radius: 8px; overflow: hidden; background-color: #f9f5ef; flex-shrink: 0;">
          <% if item.variant.product.images.attached? %>
            <%= image_tag url_for(item.variant.product.images.first), style: "width: 100%; height: 100%; object-fit: cover;" %>
          <% end %>
        </div>
        <div style="margin-left: 16px; flex: 1;">
          <p style="margin: 0; font-size: 15px; font-weight: 600; color: #0a0a0a;"><%= item.variant.product.name %></p>
          <p style="margin: 4px 0 0; font-size: 13px; color: #6b7280;">Qty: <%= item.quantity %></p>
        </div>
        <div style="text-align: right;">
          <p style="margin: 0; font-size: 15px; font-weight: 600; color: #0a0a0a;"><%= item.subtotal.format %></p>
        </div>
      </div>
    <% end %>

    <div style="margin-top: 30px; text-align: center;">
      <a href="<%= cart_url %>"
         style="display: inline-block; padding: 14px 40px; background-color: #c9a96e; color: #0a0a0a; text-decoration: none; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-radius: 8px;">
        Complete Your Purchase
      </a>
    </div>

    <p style="margin-top: 30px; color: #9ca3af; font-size: 13px; text-align: center;">
      If you have any questions, just reply to this email.
    </p>
  </div>

  <div style="padding: 20px 30px; text-align: center; background-color: #f9f5ef;">
    <p style="margin: 0; font-size: 12px; color: #9ca3af;">
      &copy; <%= Date.current.year %> RailsyCommerce. All rights reserved.
    </p>
  </div>
</div>
