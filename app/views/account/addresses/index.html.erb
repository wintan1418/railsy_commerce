<div class="mx-auto max-w-4xl px-6 py-12">
  <div class="flex items-center justify-between">
    <h1 class="font-display text-3xl font-light" style="color: var(--black);">My <em class="italic">Addresses</em></h1>
    <%= link_to "Add Address", new_account_address_path, class: "rounded-lg px-4 py-2 text-sm font-semibold text-white", style: "background: var(--gold);" %>
  </div>
  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <% @addresses.each do |address| %>
      <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-900/5">
        <p class="text-sm font-medium"><%= address.full_name %></p>
        <p class="mt-1 text-sm" style="color: var(--mid-gray);"><%= address.one_line %></p>
        <div class="mt-3 flex gap-3">
          <%= link_to "Edit", edit_account_address_path(address), class: "text-xs font-medium", style: "color: var(--gold);" %>
          <%= button_to "Remove", account_address_path(address), method: :delete, data: { turbo_confirm: "Remove this address?" }, class: "text-xs font-medium text-red-500 cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
