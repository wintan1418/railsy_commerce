<div class="mx-auto max-w-3xl px-4 sm:px-6 py-12">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Account</p>
      <h1 class="mt-2 font-display text-3xl font-light tracking-tight" style="color: var(--black);">Notifications</h1>
    </div>
    <% if @notifications.unread.any? %>
      <%= button_to "Mark All Read", mark_all_read_account_notifications_path, method: :post,
        class: "rounded-lg px-4 py-2 text-sm font-medium transition-colors duration-200 cursor-pointer hover:opacity-90",
        style: "background: var(--gold); color: var(--black);" %>
    <% end %>
  </div>

  <div class="mt-8 space-y-3">
    <% if @notifications.any? %>
      <% @notifications.each do |notification| %>
        <div class="flex items-start gap-4 rounded-xl p-5 ring-1 transition-all duration-200 <%= notification.read? ? 'ring-gray-900/5 bg-white' : 'ring-[var(--gold)]/30 bg-[var(--cream)]' %>">
          <!-- Icon -->
          <div class="flex-shrink-0 mt-0.5">
            <% case notification.notification_type %>
            <% when "order" %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full" style="background: rgba(201,169,110,0.15); color: var(--gold);">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
              </div>
            <% when "promo" %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full" style="background: rgba(201,169,110,0.15); color: var(--gold);">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                </svg>
              </div>
            <% when "system" %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100" style="color: var(--mid-gray);">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                </svg>
              </div>
            <% else %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full" style="background: rgba(201,169,110,0.15); color: var(--gold);">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-sm font-semibold truncate" style="color: var(--black);"><%= notification.title %></h3>
              <% unless notification.read? %>
                <span class="flex-shrink-0 inline-block h-2 w-2 rounded-full" style="background: var(--gold);"></span>
              <% end %>
            </div>
            <% if notification.body.present? %>
              <p class="mt-1 text-sm" style="color: var(--text-body);"><%= notification.body %></p>
            <% end %>
            <div class="mt-2 flex items-center gap-4">
              <span class="text-xs" style="color: var(--mid-gray);"><%= time_ago_in_words(notification.created_at) %> ago</span>
              <% if notification.url.present? %>
                <%= link_to "View", notification.url, class: "text-xs font-medium transition-colors hover:opacity-70", style: "color: var(--gold);" %>
              <% end %>
              <% unless notification.read? %>
                <%= button_to "Mark Read", mark_read_account_notification_path(notification), method: :post,
                  class: "text-xs font-medium cursor-pointer transition-colors hover:opacity-70",
                  style: "color: var(--mid-gray);" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="rounded-xl p-12 text-center" style="background: var(--cream);">
        <svg class="mx-auto h-12 w-12" style="color: var(--light-gray);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
        </svg>
        <p class="mt-4 text-sm" style="color: var(--mid-gray);">No notifications yet.</p>
      </div>
    <% end %>
  </div>
</div>
