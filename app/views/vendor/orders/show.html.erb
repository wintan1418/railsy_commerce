<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Order <%= @order.number %></h1>
    <p class="mt-1 text-sm text-gray-500">Customer: <%= @order.email %></p>
  </div>
  <% if @order.tracking_number.present? %>
    <span class="rounded-lg px-4 py-2 text-sm font-medium bg-gray-100">Tracking: <%= @order.tracking_number %></span>
  <% end %>
</div>

<!-- Items -->
<div class="mt-6 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
  <h2 class="text-base font-semibold text-gray-900 mb-4">Your Items in This Order</h2>
  <% @order_items.each do |item| %>
    <div class="flex justify-between py-3 border-b border-gray-100 last:border-0">
      <div>
        <p class="text-sm font-medium text-gray-900"><%= item.variant.product.name %></p>
        <p class="text-xs text-gray-500">Qty: <%= item.quantity %> | <%= item.unit_price.format %> each</p>
      </div>
      <p class="text-sm font-medium"><%= item.total.format %></p>
    </div>
  <% end %>
</div>

<!-- Tracking Timeline -->
<div class="mt-8 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
  <h2 class="text-base font-semibold text-gray-900 mb-6">Delivery Timeline</h2>
  <% if @tracking_updates.any? %>
    <div class="relative pl-8">
      <div class="absolute left-3 top-2 bottom-2 w-0.5 bg-gray-200"></div>
      <% @tracking_updates.each_with_index do |update, idx| %>
        <div class="relative pb-6 last:pb-0">
          <div class="absolute -left-5 top-1 flex h-4 w-4 items-center justify-center rounded-full <%= idx == @tracking_updates.size - 1 ? 'bg-green-500' : 'bg-gray-300' %>">
            <div class="h-2 w-2 rounded-full bg-white"></div>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900"><%= update.friendly_status %></p>
            <p class="text-xs text-gray-500"><%= update.created_at.strftime("%b %d, %Y at %I:%M %p") %></p>
            <p class="mt-1 text-sm text-gray-600"><%= update.description %></p>
            <% if update.location.present? %>
              <p class="mt-0.5 text-xs text-gray-400">Location: <%= update.location %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400">No tracking updates yet.</p>
  <% end %>
</div>

<!-- Add Tracking Update -->
<div class="mt-8 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-900/5 p-6">
  <h2 class="text-base font-semibold text-gray-900 mb-4">Update Tracking</h2>
  <%= form_with url: vendor_order_path(@order), method: :patch, class: "space-y-4" do |form| %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700">Status</label>
        <select name="tracking_update[status]" required class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
          <% TrackingUpdate::STATUSES.each do |s| %>
            <option value="<%= s %>"><%= TrackingUpdate::FRIENDLY_NAMES[s] %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Location</label>
        <input type="text" name="tracking_update[location]" placeholder="e.g., Lagos Sorting Center" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Description</label>
      <textarea name="tracking_update[description]" required rows="2" placeholder="Describe the update..." class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm resize-none"></textarea>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700">Tracking Number</label>
        <input type="text" name="tracking_number" value="<%= @order.tracking_number %>" placeholder="Enter tracking number" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Estimated Delivery</label>
        <input type="datetime-local" name="tracking_update[estimated_delivery]" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm">
      </div>
    </div>
    <button type="submit" class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white cursor-pointer" style="background: var(--gold); color: var(--black);">
      Add Update
    </button>
  <% end %>
</div>
