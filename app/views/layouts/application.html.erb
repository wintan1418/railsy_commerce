<!DOCTYPE html>
<html class="h-full scroll-smooth">
  <head>
    <title><%= content_for(:title) || "RailsyCommerce" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="RailsyCommerce">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0a0a0a">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-full antialiased">
    <!-- Announcement Ticker -->
    <div class="relative overflow-hidden" style="background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);" data-controller="ticker">
      <div class="mx-auto max-w-7xl px-4 py-2 sm:px-6 lg:px-8">
        <div class="relative h-5 overflow-hidden">
          <% [
            "Free shipping on all orders over <strong>$75</strong> — no code needed",
            "New products added daily — <strong>Explore what's new</strong>",
            "Use code <strong>WELCOME20</strong> for 20% off your first order"
          ].each_with_index do |msg, i| %>
            <p data-ticker-target="message"
               class="absolute inset-0 flex items-center justify-center text-center text-xs font-medium tracking-wide transition-all duration-500 <%= i == 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-full' %>"
               style="color: var(--black);">
              <%= raw msg %>
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <%= render "shared/header" %>

    <!-- Toast Notifications (floating, auto-dismiss) -->
    <div class="fixed top-20 left-4 right-4 sm:left-auto z-[100] flex flex-col gap-3 pointer-events-none sm:max-w-[400px]">
      <% if flash[:notice] %>
        <div data-controller="toast" data-action="click->toast#dismiss"
          class="pointer-events-auto flex items-center gap-3 rounded-lg px-5 py-4 shadow-lg ring-1 ring-black/5 transition-all duration-300 cursor-pointer"
          style="background: var(--black); color: white;">
          <svg class="h-5 w-5 flex-shrink-0" style="color: var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-sm font-medium"><%= flash[:notice] %></p>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div data-controller="toast" data-action="click->toast#dismiss"
          class="pointer-events-auto flex items-center gap-3 rounded-lg px-5 py-4 shadow-lg ring-1 ring-black/5 transition-all duration-300 cursor-pointer"
          style="background: var(--red); color: white;">
          <svg class="h-5 w-5 flex-shrink-0 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
          <p class="text-sm font-medium"><%= flash[:alert] %></p>
        </div>
      <% end %>
    </div>

    <main class="w-full max-w-none flex-1">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>

    <!-- Chat Widget -->
    <%= render "shared/chat_widget" %>

    <!-- PWA Service Worker Registration -->
    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker.js", { scope: "/" })
          .then((reg) => console.log("SW registered:", reg.scope))
          .catch((err) => console.log("SW registration failed:", err))
      }
    </script>
  </body>
</html>
