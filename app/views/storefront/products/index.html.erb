<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <!-- Page Header -->
  <div class="border-b pb-6" style="border-color: var(--cream);">
    <p class="text-xs font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">
      <% if params[:q].present? %>
        Search Results
      <% elsif params[:on_sale] %>
        Limited Time
      <% else %>
        Collection
      <% end %>
    </p>
    <h1 class="mt-2 font-display text-3xl font-light tracking-tight sm:text-4xl" style="color: var(--black);">
      <% if params[:q].present? %>
        Results for "<%= params[:q] %>"
      <% elsif params[:on_sale] %>
        Sale <em class="italic">Items</em>
      <% else %>
        All <em class="italic">Products</em>
      <% end %>
    </h1>
    <p class="mt-2 text-sm" style="color: var(--mid-gray);"><%= @products.count %> products</p>
  </div>

  <div class="mt-8 lg:grid lg:grid-cols-4 lg:gap-x-8">
    <!-- Sidebar Filters -->
    <aside class="hidden lg:block">
      <div class="sticky top-24 space-y-8">
        <!-- Category Filter -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--black);">Categories</h3>
          <ul class="mt-4 space-y-2">
            <%= link_to products_path(params.permit(:q, :sort, :on_sale)),
              class: "block text-sm transition-colors duration-200",
              style: params[:category_id].blank? ? "color: var(--gold); font-weight: 600;" : "color: var(--mid-gray);" do %>
              All Categories
            <% end %>
            <% @categories.each do |category| %>
              <li>
                <%= link_to category.name,
                  products_path(params.permit(:q, :sort, :on_sale).merge(category_id: category.id)),
                  class: "block text-sm transition-colors duration-200",
                  style: params[:category_id].to_s == category.id.to_s ? "color: var(--gold); font-weight: 600;" : "color: var(--mid-gray);" %>
              </li>
            <% end %>
          </ul>
        </div>

        <!-- Price Range Filter -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--black);">Price Range</h3>
          <ul class="mt-4 space-y-2">
            <li><a href="#" class="block text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: var(--mid-gray);">Under $50</a></li>
            <li><a href="#" class="block text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: var(--mid-gray);">$50 - $100</a></li>
            <li><a href="#" class="block text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: var(--mid-gray);">$100 - $200</a></li>
            <li><a href="#" class="block text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: var(--mid-gray);">$200 - $500</a></li>
            <li><a href="#" class="block text-sm transition-colors duration-200 hover:text-[var(--gold)]" style="color: var(--mid-gray);">Over $500</a></li>
          </ul>
        </div>

        <!-- Color Swatches -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--black);">Colors</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            <% { "Black" => "bg-gray-900", "White" => "bg-white border border-gray-300", "Navy" => "bg-blue-900", "Red" => "bg-red-500", "Blue" => "bg-blue-500", "Green" => "bg-green-600", "Olive" => "bg-green-800", "Sand" => "bg-amber-200" }.each do |name, classes| %>
              <button type="button" title="<%= name %>" class="h-7 w-7 rounded-full <%= classes %> ring-offset-2 hover:ring-2 transition-all duration-200" style="--tw-ring-color: var(--gold);"></button>
            <% end %>
          </div>
        </div>

        <!-- Sale Filter -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--black);">Deals</h3>
          <div class="mt-4">
            <%= link_to "On Sale", products_path(params.permit(:q, :sort, :category_id).merge(on_sale: true)),
              class: "inline-flex items-center gap-2 text-sm transition-colors duration-200",
              style: params[:on_sale] ? "color: var(--red); font-weight: 600;" : "color: var(--mid-gray);" %>
          </div>
        </div>
      </div>
    </aside>

    <!-- Product Grid -->
    <div class="lg:col-span-3">
      <!-- Sort & Active Filters -->
      <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <!-- Active Filter Chips -->
        <div class="flex flex-wrap items-center gap-2">
          <% if params[:category_id].present? %>
            <% cat = Category.find_by(id: params[:category_id]) %>
            <% if cat %>
              <%= link_to products_path(params.permit(:q, :sort, :on_sale)),
                class: "inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium transition-colors duration-200",
                style: "background: var(--gold-light); color: var(--black);" do %>
                <%= cat.name %>
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              <% end %>
            <% end %>
          <% end %>
          <% if params[:on_sale] %>
            <%= link_to products_path(params.permit(:q, :sort, :category_id)),
              class: "inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium text-white transition-colors duration-200",
              style: "background: var(--red);" do %>
              On Sale
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            <% end %>
          <% end %>
        </div>

        <!-- Sort Dropdown -->
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <label for="sort" class="text-sm whitespace-nowrap" style="color: var(--mid-gray);">Sort by:</label>
          <select id="sort" onchange="window.location.href = this.value"
            class="flex-1 sm:flex-none rounded-lg border py-2 pl-3 pr-8 text-sm min-h-[44px] focus:outline-none focus:ring-1"
            style="border-color: var(--cream); background: white; color: var(--black); --tw-ring-color: var(--gold);">
            <option value="<%= products_path(params.permit(:q, :category_id, :on_sale).merge(sort: 'newest')) %>" <%= 'selected' if params[:sort] == 'newest' || params[:sort].blank? %>>Newest</option>
            <option value="<%= products_path(params.permit(:q, :category_id, :on_sale).merge(sort: 'price_asc')) %>" <%= 'selected' if params[:sort] == 'price_asc' %>>Price: Low to High</option>
            <option value="<%= products_path(params.permit(:q, :category_id, :on_sale).merge(sort: 'price_desc')) %>" <%= 'selected' if params[:sort] == 'price_desc' %>>Price: High to Low</option>
            <option value="<%= products_path(params.permit(:q, :category_id, :on_sale).merge(sort: 'name_asc')) %>" <%= 'selected' if params[:sort] == 'name_asc' %>>Name: A-Z</option>
          </select>
        </div>
      </div>

      <!-- Mobile Category Pills -->
      <div class="mb-6 flex overflow-x-auto gap-2 pb-2 lg:hidden scrollbar-hide -mx-4 px-4">
        <%= link_to "All", products_path(params.permit(:q, :sort, :on_sale)),
          class: "flex-shrink-0 rounded-full px-4 py-2 min-h-[44px] inline-flex items-center text-sm font-medium transition-colors duration-200",
          style: params[:category_id].blank? ? "background: var(--gold); color: var(--black);" : "background: var(--cream); color: var(--text-body);" %>
        <% @categories.each do |category| %>
          <%= link_to category.name,
            products_path(params.permit(:q, :sort, :on_sale).merge(category_id: category.id)),
            class: "flex-shrink-0 rounded-full px-4 py-2 min-h-[44px] inline-flex items-center text-sm font-medium transition-colors duration-200",
            style: params[:category_id].to_s == category.id.to_s ? "background: var(--gold); color: var(--black);" : "background: var(--cream); color: var(--text-body);" %>
        <% end %>
      </div>

      <% if @products.any? %>
        <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-6">
          <% @products.each do |product| %>
            <%= render "storefront/products/product_card", product: product %>
          <% end %>
        </div>
      <% else %>
        <div class="py-24 text-center">
          <svg class="mx-auto h-12 w-12" style="color: var(--light-gray);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <h3 class="mt-4 font-display text-lg font-semibold" style="color: var(--black);">No products found</h3>
          <p class="mt-2 text-sm" style="color: var(--mid-gray);">Try adjusting your search or filters to find what you're looking for.</p>
          <div class="mt-6">
            <%= link_to "Clear all filters", products_path,
              class: "text-sm font-medium",
              style: "color: var(--gold);" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
