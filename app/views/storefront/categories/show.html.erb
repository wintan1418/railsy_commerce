<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8">
    <%= link_to "Home", root_path, class: "hover:text-gray-600 transition-colors duration-200" %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <% if @category.parent %>
      <%= link_to @category.parent.name, category_path(slug: @category.parent.slug), class: "hover:text-gray-600 transition-colors duration-200" %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <% end %>
    <span class="text-gray-700 font-medium"><%= @category.name %></span>
  </nav>

  <!-- Category Header -->
  <div class="border-b border-gray-200 pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= @category.name %></h1>
    <% if @category.description.present? %>
      <p class="mt-3 text-gray-500 max-w-2xl"><%= @category.description %></p>
    <% end %>
  </div>

  <!-- Subcategories -->
  <% if @subcategories.any? %>
    <div class="mt-6 flex flex-wrap gap-2">
      <% @subcategories.each do |sub| %>
        <%= link_to sub.name, category_path(slug: sub.slug),
          class: "rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-200" %>
      <% end %>
    </div>
  <% end %>

  <!-- Products Grid -->
  <% if @products.any? %>
    <div class="mt-10 grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4 lg:gap-x-6">
      <% @products.each do |product| %>
        <%= render "storefront/products/product_card", product: product %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-20 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">No products yet</h3>
      <p class="mt-2 text-sm text-gray-500">Check back soon for new additions to this category.</p>
      <div class="mt-6">
        <%= link_to "Browse all products", products_path,
          class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 transition-colors duration-200" %>
      </div>
    </div>
  <% end %>
</div>
