<header class="bg-white shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="flex items-center gap-8">
        <%= link_to "RailsyCommerce", root_path, class: "text-xl font-bold text-gray-900" %>
        <div class="hidden sm:flex gap-6">
          <%= link_to "Products", products_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <% if defined?(current_cart) %>
          <%= link_to cart_path, class: "relative text-gray-700 hover:text-gray-900" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
            <% if current_cart.item_count > 0 %>
              <span class="absolute -top-2 -right-2 bg-indigo-600 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center" id="cart-count">
                <%= current_cart.item_count %>
              </span>
            <% end %>
          <% end %>
        <% end %>

        <% if authenticated? %>
          <div class="flex items-center gap-3">
            <% if current_user&.admin? %>
              <%= link_to "Admin", admin_root_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
            <% end %>
            <span class="text-sm text-gray-600"><%= current_user&.first_name %></span>
            <%= button_to "Sign out", session_path, method: :delete, class: "text-sm font-medium text-gray-700 hover:text-gray-900 cursor-pointer" %>
          </div>
        <% else %>
          <%= link_to "Sign in", new_session_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
          <%= link_to "Sign up", new_registration_path, class: "text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg" %>
        <% end %>
      </div>
    </div>
  </nav>
</header>
